<div id="bgm-container" transition:persist="bgm-player" class="fixed bottom-[16px] md:bottom-[24px] right-[16px] md:right-[24px] z-50">
    <!-- Tooltip -->
    <div class="absolute -top-[40px] right-0 bg-black text-white text-[12px] font-bold font-mono px-[12px] py-[6px] rounded-[4px] whitespace-nowrap opacity-0 transition-opacity duration-300 pointer-events-none" id="bgm-tooltip">
        BGM: Off
    </div>

    <!-- Toggle Button -->
    <button id="bgm-toggle" class="w-[36px] h-[36px] md:w-[48px] md:h-[48px] bg-[#ECA243] border-[2px] md:border-[3px] border-[var(--color-carbon-black)] rounded-none shadow-[2px_2px_0_#000] md:shadow-[4px_4px_0_#000] flex items-center justify-center hover:translate-y-[2px] hover:shadow-[1px_1px_0_#000] transition-all active:brightness-90 cursor-pointer group" aria-label="Toggle Background Music">
        <!-- Speaker Icon (On) -->
        <svg id="icon-unmuted" class="w-[24px] h-[24px] hidden text-black" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
        
        <!-- Speaker Icon (Off/Muted) -->
        <svg id="icon-muted" class="w-[24px] h-[24px] text-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
            <line x1="23" y1="9" x2="17" y2="15"></line>
            <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
    </button>

    <!-- Background Music Audio Tag -->
    <audio id="bgm-audio" loop preload="auto">
        <source src="/music/ground-theme.mp3" type="audio/mpeg" />
    </audio>
</div>

<script>
    // Variables declared outside so they can be reused across page loads
    let hasAttemptedAutoPlay = false;

    document.addEventListener('astro:page-load', () => {
        const bgmToggle = document.getElementById('bgm-toggle');
        const bgmAudio = document.getElementById('bgm-audio') as HTMLAudioElement;
        const iconUnmuted = document.getElementById('icon-unmuted');
        const iconMuted = document.getElementById('icon-muted');
        const tooltip = document.getElementById('bgm-tooltip');

        if (!bgmToggle || !bgmAudio) return;

        const updateUI = () => {
            if (!bgmAudio.paused && bgmAudio.volume > 0) {
                iconMuted?.classList.add('hidden');
                iconUnmuted?.classList.remove('hidden');
                if(tooltip) tooltip.innerText = 'BGM: On';
                bgmToggle.classList.replace('bg-[#ECA243]', 'bg-[var(--color-lime-pulse)]');
            } else {
                iconUnmuted?.classList.add('hidden');
                iconMuted?.classList.remove('hidden');
                if(tooltip) tooltip.innerText = 'BGM: Off';
                bgmToggle.classList.replace('bg-[var(--color-lime-pulse)]', 'bg-[#ECA243]');
            }
        };

        // Initialize UI state in case it's playing from a previous page
        updateUI();

        // Prevent attaching duplicate listeners if already initialized
        if (bgmToggle.dataset.initialized) {
            return;
        }
        bgmToggle.dataset.initialized = 'true';

        // Show tooltip on hover
        bgmToggle.addEventListener('mouseenter', () => {
            if(tooltip) tooltip.style.opacity = '1';
        });
        bgmToggle.addEventListener('mouseleave', () => {
            if(tooltip) tooltip.style.opacity = '0';
        });

        const tryAutoPlay = () => {
            if (hasAttemptedAutoPlay) return;
            hasAttemptedAutoPlay = true;
            
            if (bgmAudio && bgmAudio.paused) {
                bgmAudio.volume = 0.2;
                bgmAudio.play().then(() => {
                    updateUI();
                }).catch(e => console.log("Autoplay blocked."));
            }
            document.removeEventListener('click', tryAutoPlay);
        };

        document.addEventListener('click', tryAutoPlay);

        // Manual toggle
        bgmToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            hasAttemptedAutoPlay = true;
            
            if (!bgmAudio.paused && bgmAudio.volume > 0) {
                // Force pause and mute
                bgmAudio.pause();
                bgmAudio.volume = 0;
                updateUI();
            } else {
                // Force play and unmute
                bgmAudio.volume = 0.2;
                bgmAudio.play().then(() => {
                    updateUI();
                }).catch(e => console.error(e));
            }
        });

        // Handle end of song or state changes from browser media controls
        bgmAudio.addEventListener('pause', updateUI);
        bgmAudio.addEventListener('play', updateUI);
    });
</script>
