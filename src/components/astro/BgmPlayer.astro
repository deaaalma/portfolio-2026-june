<div id="bgm-container" class="fixed bottom-[16px] md:bottom-[24px] right-[16px] md:right-[24px] z-50">
    <!-- Tooltip -->
    <div class="absolute -top-[40px] right-0 bg-black text-white text-[12px] font-bold font-mono px-[12px] py-[6px] rounded-[4px] whitespace-nowrap opacity-0 transition-opacity duration-300 pointer-events-none" id="bgm-tooltip">
