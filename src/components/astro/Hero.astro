---
import Badge from './Badge.astro';
import Button from './Button.astro';
import { Image } from 'astro:assets';
import faceImage from '../../assets/images/face.png';
import gmailPixel from '../../assets/images/gmail-pixel.png';
import linkedinPixel from '../../assets/images/linkedin-pixel.png';
import whatsappPixel from '../../assets/images/whatsapp-pixel.png';
import githubPixel from '../../assets/images/github-pixel.png';
---

<section id="about" class="relative w-full min-h-screen bg-gradient-to-b from-[#7dd3fc] via-[#bae6fd] to-[#ffffff] pt-[140px] md:pt-[180px] pb-[160px] overflow-hidden flex flex-col items-center">
  
  <!-- Retro HUD (Initially Visible) -->
  <div id="retro-hud" class="absolute top-[24px] left-0 w-full px-[24px] md:px-[48px] flex justify-between text-white text-[16px] md:text-[24px] z-40 transition-all duration-700" style="font-family: 'Mario', sans-serif; -webkit-text-stroke: 2px black; text-shadow: 4px 4px 0 #000;">
    <div class="flex flex-col items-center">
       <span>DEA</span>
       <span>000000</span>
    </div>
    <div class="flex flex-col items-center hidden md:flex">
       <span>EXPERIENCE</span>
       <span>LEVEL 3</span>
    </div>
    <div class="flex flex-col items-center">
       <span>PROJECTS</span>
       <span>5</span>
    </div>
    <div class="flex flex-col items-center hidden md:flex">
       <span>TIME</span>
       <span>♾️</span>
    </div>
  </div>

  <!-- Pixel Clouds (Evenly Distributed) -->
  <!-- Top Row -->
  <div class="absolute top-[5%] left-[5%] opacity-80 animate-pulse z-20" style="animation-duration: 3s;">
    <svg class="w-[90px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[12%] left-[25%] opacity-65 z-20" style="animation-duration: 5s;">
    <svg class="w-[130px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[8%] right-[15%] opacity-90 animate-bounce z-20" style="animation-duration: 4s;">
    <svg class="w-[150px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[20%] right-[40%] opacity-75 z-20">
    <svg class="w-[100px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>

  <!-- Middle Row -->
  <div class="absolute top-[35%] left-[8%] opacity-85 z-20" style="animation-duration: 6s;">
    <svg class="w-[160px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[40%] right-[5%] opacity-70 animate-pulse z-20" style="animation-duration: 4s;">
    <svg class="w-[120px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[55%] left-[30%] opacity-90 z-20">
    <svg class="w-[110px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[50%] right-[25%] opacity-80 animate-bounce z-20" style="animation-duration: 5s;">
    <svg class="w-[140px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>

  <!-- Bottom Row -->
  <div class="absolute top-[75%] left-[5%] opacity-75 animate-pulse z-20" style="animation-duration: 3s;">
    <svg class="w-[120px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[85%] right-[10%] opacity-65 z-20">
    <svg class="w-[90px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[80%] left-[45%] opacity-85 z-20" style="animation-duration: 6s;">
    <svg class="w-[150px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>
  <div class="absolute top-[70%] right-[40%] opacity-90 animate-pulse z-20" style="animation-duration: 4s;">
    <svg class="w-[130px] h-auto cursor-pointer hover:scale-125 hover:brightness-110 transition-all duration-300" viewBox="0 0 24 16" fill="white" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated;"><path d="M7 2h6v2h4v2h2v2h2v6H3v-4H1V8h2V6h2V4h2V2z" /></svg>
  </div>

  <!-- Main Content Container -->
  <div id="hero-main-container" class="relative max-w-[1200px] w-full mx-auto px-[12px] md:px-[24px] z-30 flex flex-col items-center mt-[140px] md:mt-[180px]">
    
    <!-- Giant HELLO WORLD Mario Style -->
    <h1 id="hello-world-title" class="text-center text-[44px] sm:text-[56px] md:text-[140px] leading-[1.1] uppercase drop-shadow-[4px_4px_0_#000] flex flex-wrap justify-center gap-x-2 md:gap-x-4 mb-[40px] md:mb-[80px]" style="font-family: 'Mario', sans-serif; -webkit-text-stroke: 8px black; paint-order: stroke fill;">
      <div class="flex">
        <span class="text-[#E52521] hover:-translate-y-4 transition-transform cursor-pointer">H</span>
        <span class="text-[#049CD8] hover:-translate-y-4 transition-transform cursor-pointer">E</span>
        <span class="text-[#FBD000] hover:-translate-y-4 transition-transform cursor-pointer">L</span>
        <span class="text-[#43B047] hover:-translate-y-4 transition-transform cursor-pointer">L</span>
        <span class="text-[#E52521] hover:-translate-y-4 transition-transform cursor-pointer">O</span>
      </div>
      <div class="flex ml-[16px] md:ml-[32px]">
        <span class="text-[#049CD8] hover:-translate-y-4 transition-transform cursor-pointer">W</span>
        <span class="text-[#FBD000] hover:-translate-y-4 transition-transform cursor-pointer">O</span>
        <span class="text-[#43B047] hover:-translate-y-4 transition-transform cursor-pointer">R</span>
        <span class="text-[#E52521] hover:-translate-y-4 transition-transform cursor-pointer">L</span>
        <span class="text-[#049CD8] hover:-translate-y-4 transition-transform cursor-pointer">D</span>
        <span class="text-[#E52521] hover:-translate-y-4 transition-transform cursor-pointer">!</span>
      </div>
    </h1>

    <!-- PRESS START BUTTON (Initially Visible) -->
    <div id="press-start-btn" class="flex flex-col items-center justify-center cursor-pointer hover:scale-110 transition-all duration-300 z-40 mt-[20px] md:mt-[40px]">
      <div class="text-white text-[20px] md:text-[32px] font-bold animate-pulse drop-shadow-[2px_2px_0_#000]" style="font-family: 'Mario', sans-serif; -webkit-text-stroke: 1px black;">
        &gt; PRESS START TO PLAY &lt;
      </div>
    </div>

    <!-- Restored Widget (Mockup Card) adapted for Portfolio (Initially Hidden) -->
    <!-- Restored Widget (Mockup Card) adapted for Portfolio (Initially Hidden) -->
    <div id="hero-widget" class="absolute top-[160px] md:top-[220px] opacity-0 translate-y-[50px] pointer-events-none transition-all duration-1000 w-full max-w-[1200px] min-h-fit md:min-h-[500px] h-auto bg-[var(--color-fog)] border-[3px] border-[var(--color-carbon-black)] rounded-none shadow-[8px_8px_0_#000] overflow-visible flex flex-col mx-auto z-10 text-left">
      
      <!-- Face Image has been moved to panel-about for better mobile flow -->
      <!-- Widget Header (Floating Tag) -->
      <div class="absolute top-[-32px] md:top-[-38px] left-[-3px] bg-[#FBD000] border-[3px] border-black px-[12px] md:px-[16px] py-[2px] md:py-[4px] shadow-[4px_4px_0_#000] z-50 hover:-translate-y-1 transition-transform cursor-pointer">
        <span class="text-[14px] md:text-[18px] tracking-wider text-black" style="font-family: 'Poppin', sans-serif;">ABOUT ME</span>
      </div>

      <!-- Browser Chrome / Top Bar -->
      <div id="widget-drag-handle" class="flex items-center justify-between px-[16px] py-[8px] border-b-[3px] border-black bg-[var(--color-paper-white)] rounded-none cursor-move select-none">
        <div class="flex items-center gap-[16px]">
            <!-- Mac-style Window Controls -->
            <div class="flex items-center gap-[6px] md:gap-[8px]">
              <span class="w-[10px] h-[10px] md:w-[14px] md:h-[14px] rounded-full bg-[#E52521] border-[1.5px] border-black"></span>
              <span class="w-[10px] h-[10px] md:w-[14px] md:h-[14px] rounded-full bg-[#FBD000] border-[1.5px] border-black"></span>
              <span class="w-[10px] h-[10px] md:w-[14px] md:h-[14px] rounded-full bg-[#43B047] border-[1.5px] border-black"></span>
            </div>
        </div>
        <div class="flex items-center gap-[8px] md:gap-[12px]">
            <div id="retro-clock" class="text-[10px] md:text-[13px] font-bold font-mono tracking-widest text-black mt-[1px]">12:00 AM</div>
            <div class="w-[20px] h-[20px] md:w-[24px] md:h-[24px] bg-[var(--color-lime-pulse)] border-2 border-black flex items-center justify-center shadow-[2px_2px_0_#000]">
              <svg width="10" height="10" class="md:w-[12px] md:h-[12px]" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </div>
        </div>
      </div>

      <div class="flex flex-col md:flex-row flex-1 overflow-hidden font-mono text-[var(--color-carbon-black)]">
        <!-- Sidebar -->
        <div class="w-full md:w-[240px] border-b-[3px] md:border-b-0 md:border-r-[3px] border-[var(--color-carbon-black)] bg-[var(--color-paper-white)] flex flex-col p-[8px] md:p-[16px] shrink-0">
          <div class="flex flex-row md:flex-col gap-[8px] md:gap-[12px] mb-0 md:mb-[32px] overflow-x-auto hide-scrollbar pb-[4px] md:pb-0" id="sidebar-nav">
            <div id="nav-about" class="sidebar-btn active flex items-center gap-[6px] md:gap-[8px] bg-[var(--color-lime-pulse)] px-[10px] md:px-[12px] py-[6px] md:py-[8px] rounded-none border-2 border-black font-bold text-[12px] md:text-[14px] shadow-[2px_2px_0_#000] cursor-pointer text-black transition-all whitespace-nowrap flex-shrink-0" data-target="panel-about">
                <span class="nav-indicator">></span> <span class="nav-text">About Me</span>
            </div>
            <div id="nav-skills" class="sidebar-btn inactive flex items-center gap-[6px] md:gap-[8px] px-[10px] md:px-[12px] py-[6px] md:py-[8px] text-[var(--color-slate)] font-bold text-[12px] md:text-[14px] hover:bg-white hover:border-2 hover:border-black hover:shadow-[2px_2px_0_#000] hover:text-black border-2 border-transparent rounded-none cursor-pointer transition-all whitespace-nowrap flex-shrink-0" data-target="panel-skills">
                <span class="nav-indicator opacity-0">></span> <span class="nav-text">My Skills</span>
            </div>
            <div id="nav-education" class="sidebar-btn inactive flex items-center gap-[6px] md:gap-[8px] px-[10px] md:px-[12px] py-[6px] md:py-[8px] text-[var(--color-slate)] font-bold text-[12px] md:text-[14px] hover:bg-white hover:border-2 hover:border-black hover:shadow-[2px_2px_0_#000] hover:text-black border-2 border-transparent rounded-none cursor-pointer transition-all whitespace-nowrap flex-shrink-0" data-target="panel-education">
                <span class="nav-indicator opacity-0">></span> <span class="nav-text">Education</span>
            </div>
          </div>
          

        </div>

        <!-- Main Content -->
        <div class="flex-1 bg-[var(--color-fog)] p-[16px] md:p-[40px] relative overflow-x-hidden">
          <!-- Panel: About Me -->
          <div id="panel-about" class="content-panel flex flex-col h-fit w-full">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-[16px] gap-[12px]">
                <h2 class="text-[24px] md:text-[36px] font-bold tracking-tight type-target leading-tight" style="font-family: 'Chalkboard', cursive;">Hello! I'm Dea Alma</h2>
                <div class="flex items-center gap-[8px] md:gap-[12px] mr-0 md:mr-[24px] relative z-20">
                    <span class="text-[12px] font-bold text-[var(--color-slate)] animate-pulse hidden md:inline">● ONLINE</span>
                    <button id="hire-me-btn" onclick="document.getElementById('hire-me-modal').classList.remove('hidden'); document.getElementById('hire-me-modal').classList.add('flex');" class="border-[2px] border-[var(--color-carbon-black)] px-[12px] md:px-[16px] py-[8px] rounded-none text-[12px] md:text-[14px] bg-[var(--color-lime-pulse)] shadow-[3px_3px_0_#000] font-bold hover:translate-y-[2px] hover:shadow-[1px_1px_0_#000] transition-all active:brightness-90">Hire Me</button>
                </div>
            </div>
            
            <div class="flex flex-col gap-[24px] md:gap-[32px] max-w-[540px] relative z-20">
                <!-- Bio Text and Face Image Container -->
                <div class="flex flex-row items-end justify-between gap-[12px] md:block w-full">
                    <!-- Bio Text -->
                    <div class="flex-1">
                        <p class="text-[12px] md:text-[16px] leading-[1.5] md:leading-[1.7] text-[var(--color-slate)] font-medium type-target w-full">
                            6th-semester Information Technology student with experience in business systems and web applications. Familiar with ERP environments through Odoo system support and interested in how technology improves business processes and customer operations.
                        </p>
                    </div>
                    
                    <!-- Face Image (Inline on mobile, Absolute on Desktop) -->
                    <a href="/cv_putu_ayu_deanisa.pdf" target="_blank" class="relative md:absolute md:bottom-[-40px] md:right-[20px] shrink-0 block cursor-pointer z-50 hover:-translate-y-2 transition-transform duration-300 animate-float">
                        <!-- Speech Bubble Tooltip -->
                        <div class="absolute top-[0px] md:top-[30px] left-1/2 -translate-x-1/2 bg-[var(--color-paper-white)] border-[2px] md:border-[3px] border-black px-[8px] md:px-[12px] py-[4px] md:py-[8px] shadow-[2px_2px_0_#000] md:shadow-[4px_4px_0_#000] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap z-50">
                            <span class="text-[9px] md:text-[14px] font-bold text-black font-mono tracking-tighter">Want to see my resume?</span>
                            <div class="absolute bottom-[-6px] md:bottom-[-7px] left-[50%] -translate-x-1/2 w-[8px] md:w-[10px] h-[8px] md:h-[10px] bg-[var(--color-paper-white)] border-b-[2px] md:border-b-[3px] border-r-[2px] md:border-r-[3px] border-black transform rotate-45"></div>
                        </div>
                        <Image src={faceImage} alt="Dea Alma" width={280} class="block w-[100px] sm:w-[130px] md:w-[280px] h-auto object-contain drop-shadow-[2px_2px_0_#000] md:drop-shadow-[4px_4px_0_#000] group-hover:drop-shadow-[4px_4px_0_var(--color-lime-pulse)] md:group-hover:drop-shadow-[6px_6px_0_var(--color-lime-pulse)] transition-all duration-300" style="image-rendering: pixelated;" />
                    </a>
                </div>
                
                <!-- Details Row -->
                <div class="grid grid-cols-3 gap-[6px] md:gap-[16px] pb-[40px] md:pb-0 w-full">
                    <!-- Current GPA -->
                    <div class="border-[2px] md:border-[3px] border-black bg-[var(--color-amber-spark)] p-[6px] md:p-[16px] shadow-[2px_2px_0_#000] md:shadow-[4px_4px_0_#000] flex flex-col justify-center">
                        <span class="text-[8px] md:text-[11px] font-bold text-gray-800 mb-[2px] md:mb-[6px] font-mono uppercase tracking-widest leading-[1.1]">GPA</span>
                        <span class="text-[10px] sm:text-[12px] md:text-[16px] font-bold tracking-tight whitespace-normal md:whitespace-nowrap leading-[1.2]">3.83/4.00</span>
                    </div>
                    <!-- Location -->
                    <div class="border-[2px] md:border-[3px] border-black bg-[#fae9ff] p-[6px] md:p-[16px] shadow-[2px_2px_0_#000] md:shadow-[4px_4px_0_#000] flex flex-col justify-center">
                        <span class="text-[8px] md:text-[11px] font-bold text-gray-600 mb-[2px] md:mb-[6px] font-mono uppercase tracking-widest leading-[1.1]">Location</span>
                        <span class="text-[10px] sm:text-[12px] md:text-[16px] font-bold tracking-tight whitespace-normal md:whitespace-nowrap leading-[1.2]">Bali, ID</span>
                    </div>
                    <!-- Education -->
                    <div class="border-[2px] md:border-[3px] border-black bg-[#d2fae5] p-[6px] md:p-[16px] shadow-[2px_2px_0_#000] md:shadow-[4px_4px_0_#000] flex flex-col justify-center">
                        <span class="text-[8px] md:text-[11px] font-bold text-gray-600 mb-[2px] md:mb-[6px] font-mono uppercase tracking-widest leading-[1.1]">Education</span>
                        <span class="text-[10px] sm:text-[12px] md:text-[16px] font-bold tracking-tight whitespace-normal md:whitespace-nowrap leading-[1.2]">Udayana U.</span>
                    </div>
                </div>
            </div>
          </div>

          <!-- Panel: My Skills -->
          <div id="panel-skills" class="content-panel hidden flex flex-col h-fit w-full">
             <div class="flex items-center justify-between mb-[16px] md:mb-[24px]">
                <h2 class="text-[20px] md:text-[36px] font-bold tracking-tight type-target leading-tight" style="font-family: 'Chalkboard', cursive;">My Skills</h2>
             </div>
             
             <!-- Grid of Retro Folders -->
             <div class="grid grid-cols-3 gap-y-[20px] md:gap-y-[32px] gap-x-[10px] md:gap-x-[16px] max-w-[540px] relative z-20 mt-[8px]">
                
                <!-- Frontend -->
                <div class="skill-folder flex flex-col items-center gap-1 md:gap-2 w-full group cursor-pointer" data-title="Frontend" data-skills="React, Astro, TypeScript, JavaScript, HTML, CSS">
                    <div class="relative w-[50px] h-[38px] md:w-[80px] md:h-[60px] group-hover:-translate-y-2 transition-transform drop-shadow-[2px_2px_0_#000] md:drop-shadow-[4px_4px_0_#000]">
                        <div class="absolute top-[-5px] md:top-[-8px] left-[-2px] w-[20px] md:w-[30px] h-[8px] md:h-[12px] bg-[#ECA243] border-t-[2px] md:border-t-[3px] border-l-[2px] md:border-l-[3px] border-r-[2px] md:border-r-[3px] border-black"></div>
                        <div class="absolute bottom-0 left-0 w-[50px] md:w-[80px] h-[38px] md:h-[60px] bg-[#ECA243] border-[2px] md:border-[3px] border-black"></div>
                        <!-- Paper sticking out -->
                        <div class="absolute bottom-[2px] md:bottom-[4px] left-[6px] md:left-[10px] w-[34px] md:w-[54px] h-[30px] md:h-[50px] bg-white border-[2px] md:border-[3px] border-black group-hover:translate-y-[-12px] md:group-hover:translate-y-[-24px] group-hover:-rotate-6 transition-all duration-300 z-10 p-[2px] md:p-[4px] overflow-hidden">
                            <p class="text-[5px] md:text-[7px] leading-[1.2] font-bold text-black font-mono">React<br/>Astro<br/>TS/JS<br/>HTML/CSS</p>
                        </div>
                        <div class="absolute bottom-0 left-0 w-[50px] md:w-[80px] h-[28px] md:h-[45px] bg-[#F4B85E] border-[2px] md:border-[3px] border-black z-20 shadow-[inset_1px_1px_0_rgba(255,255,255,0.4)] md:shadow-[inset_2px_2px_0_rgba(255,255,255,0.4)]"></div>
                    </div>
                    <span class="font-mono text-[9px] md:text-[13px] font-bold text-black tracking-tighter mt-1 px-[2px] md:px-[4px] border-[2px] border-transparent group-hover:bg-blue-600 group-hover:text-white group-hover:border-dotted group-hover:border-white">Frontend</span>
                </div>

                <!-- Backend -->
                <div class="skill-folder flex flex-col items-center gap-1 md:gap-2 w-full group cursor-pointer" data-title="Backend" data-skills="PHP, Laravel, Express">
                    <div class="relative w-[50px] h-[38px] md:w-[80px] md:h-[60px] group-hover:-translate-y-2 transition-transform drop-shadow-[2px_2px_0_#000] md:drop-shadow-[4px_4px_0_#000]">
                        <div class="absolute top-[-5px] md:top-[-8px] left-[-2px] w-[20px] md:w-[30px] h-[8px] md:h-[12px] bg-[#ECA243] border-t-[2px] md:border-t-[3px] border-l-[2px] md:border-l-[3px] border-r-[2px] md:border-r-[3px] border-black"></div>
                        <div class="absolute bottom-0 left-0 w-[50px] md:w-[80px] h-[38px] md:h-[60px] bg-[#ECA243] border-[2px] md:border-[3px] border-black"></div>
                        <!-- Paper sticking out -->
