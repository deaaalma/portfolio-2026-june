<script>
  // Lock scroll initially to force user to stay on the Title Screen (skip if intro already done)
  if (typeof window !== 'undefined' && sessionStorage.getItem('portfolio_intro_done') !== '1') {
    document.body.style.overflow = 'hidden';
  }

  const startBtn = document.getElementById('press-start-btn');
  const widget = document.getElementById('hero-widget');
  const navbar = document.getElementById('main-navbar');
  const hud = document.getElementById('retro-hud');
  const mainContent = document.getElementById('main-content');
  const divider = document.getElementById('hero-divider');
  const crtOverlay = document.getElementById('crt-overlay');
  const crtLine = document.getElementById('crt-line');
  const helloWorldTitle = document.getElementById('hello-world-title');
  const heroMainContainer = document.getElementById('hero-main-container');

  // Helper: instantly reveal homepage (no animation)
  function skipIntroInstantly() {
    if (startBtn) startBtn.classList.add('hidden');
    if (hud) hud.classList.add('hidden');
    if (helloWorldTitle) helloWorldTitle.classList.add('hidden');
    if (heroMainContainer) {
      heroMainContainer.classList.remove('mt-[100px]', 'md:mt-[180px]');
      heroMainContainer.classList.add('mt-0');
    }
    if (widget) {
      widget.classList.remove('opacity-0', 'translate-y-[50px]', 'pointer-events-none', 'absolute', 'top-[160px]', 'md:top-[220px]');
      widget.classList.add('opacity-100', 'translate-y-0', 'relative', 'mt-[20px]', 'md:mt-[40px]');
    }
    if (navbar) {
      navbar.classList.remove('opacity-0', '-translate-y-[150%]', 'pointer-events-none');
      navbar.classList.add('opacity-100', 'translate-y-0');
    }
    if (mainContent) mainContent.classList.remove('hidden', 'opacity-0');
    if (divider) divider.classList.remove('opacity-0');
    if (crtOverlay) {
      crtOverlay.classList.add('opacity-0', 'pointer-events-none');
      crtOverlay.classList.remove('opacity-100');
    }
    document.body.style.overflow = 'auto';
  }

  // If user already completed the intro in this session, skip it immediately
  if (sessionStorage.getItem('portfolio_intro_done') === '1') {
    skipIntroInstantly();
  }

   if (startBtn) {
     startBtn.addEventListener('click', () => {
        // Mark intro as done for this session
        sessionStorage.setItem('portfolio_intro_done', '1');
        
        // 2. Fast blink the start button
        startBtn.classList.add('fast-blink');
        
        setTimeout(() => {
            // 3. Turn OFF CRT (Screen goes black with white line shrinking)
            if (crtOverlay && crtLine) {
                crtOverlay.classList.remove('opacity-0');
                crtOverlay.classList.add('opacity-100');
                crtLine.classList.remove('opacity-0');
                crtLine.classList.add('animate-crt-off');
            }

            setTimeout(() => {
                // 4. While screen is pitch black, arrange the new layout behind it
                startBtn.classList.remove('fast-blink');
                startBtn.classList.add('hidden');
                if (hud) hud.classList.add('hidden');
                if (helloWorldTitle) helloWorldTitle.classList.add('hidden');
                
                if (heroMainContainer) {
                  heroMainContainer.classList.remove('mt-[100px]', 'md:mt-[180px]');
                  heroMainContainer.classList.add('mt-0');
                }
                
                if (widget) {
                  widget.classList.remove('opacity-0', 'translate-y-[50px]', 'pointer-events-none', 'absolute', 'top-[160px]', 'md:top-[220px]');
                  widget.classList.add('opacity-100', 'translate-y-0', 'relative', 'mt-[20px]', 'md:mt-[40px]');
                }
                
                if(navbar) {
                  navbar.classList.remove('opacity-0', '-translate-y-[150%]', 'pointer-events-none');
                  navbar.classList.add('opacity-100', 'translate-y-0');
                }

                if (mainContent) {
                  mainContent.classList.remove('hidden', 'opacity-0');
                }

                if (divider) {
                  divider.classList.remove('opacity-0');
                }

                // 5. Turn ON CRT (White line expands to reveal new screen)
                if (crtOverlay && crtLine) {
                    crtLine.classList.remove('animate-crt-off');
                    crtLine.classList.add('animate-crt-on');
                    
                    // After turn on animation finishes, hide the overlay line
                    setTimeout(() => {
                        crtLine.classList.remove('animate-crt-on');
                        crtLine.classList.add('opacity-0');
                        crtOverlay.classList.remove('opacity-100');
                        crtOverlay.classList.add('opacity-0', 'pointer-events-none');
                        document.body.style.overflow = 'auto'; // Enable scroll
                    }, 500);
                } else {
                    document.body.style.overflow = 'auto';
                }

            }, 400); // Duration of crt-off animation
        }, 600); // Duration of fast blink before turning off
     });
   }

   // Sidebar Navigation Logic
   const sidebarBtns = document.querySelectorAll('.sidebar-btn');
   const heroWidget = document.getElementById('hero-widget');

   sidebarBtns.forEach(btn => {
       btn.addEventListener('click', () => {
           // If already active, do nothing
           if (btn.classList.contains('active')) return;

           // Get current height before changing anything
           const startHeight = heroWidget.getBoundingClientRect().height;

           // Reset all buttons
           sidebarBtns.forEach(b => {
               b.classList.remove('active', 'bg-[var(--color-lime-pulse)]', 'text-black', 'border-black', 'shadow-[2px_2px_0_#000]');
               b.classList.add('inactive', 'text-[var(--color-slate)]', 'border-transparent');
               b.querySelector('.nav-indicator').classList.add('opacity-0');
               b.style.border = ''; // Remove inline style
           });
           
           // Add active state to clicked
           btn.classList.remove('inactive', 'text-[var(--color-slate)]', 'hover:bg-white', 'hover:border-black', 'hover:shadow-[2px_2px_0_#000]', 'hover:text-black', 'border-transparent');
           btn.classList.add('active', 'bg-[var(--color-lime-pulse)]', 'text-black', 'border-black', 'shadow-[2px_2px_0_#000]');
           btn.querySelector('.nav-indicator').classList.remove('opacity-0');
           btn.style.border = ''; // Remove inline style
           
           // Hide all content panels
           document.querySelectorAll('.content-panel').forEach(panel => {
               panel.classList.add('hidden');
           });
           
           // Temporarily fix height to startHeight to avoid jumping
           heroWidget.style.transition = 'none';
           heroWidget.style.height = startHeight + 'px';
           
           // Show target panel
           const targetId = btn.getAttribute('data-target');
           if(targetId) {
             const targetPanel = document.getElementById(targetId);
             if(targetPanel) targetPanel.classList.remove('hidden');
           }

           // Get the new natural height
           heroWidget.style.height = 'auto';
           const endHeight = heroWidget.getBoundingClientRect().height;
           
           // Revert back to startHeight instantly
           heroWidget.style.height = startHeight + 'px';
           
           // Force browser reflow so it registers the start height before animating
           void heroWidget.offsetHeight;
           
           // Animate to endHeight
           heroWidget.style.transition = 'height 0.4s cubic-bezier(0.25, 1, 0.5, 1)';
           heroWidget.style.height = endHeight + 'px';
           
           // Clean up inline styles after animation finishes
           setTimeout(() => {
               heroWidget.style.height = 'auto';
               heroWidget.style.transition = ''; // Returns control to Tailwind classes
           }, 400);
       });
   });

   // Skill Folder Modal Logic
   const skillFolders = document.querySelectorAll('.skill-folder');
   
   const skillIcons = {
       'React': 'https://cdn.simpleicons.org/react',
       'Astro': 'https://cdn.simpleicons.org/astro',
       'TypeScript': 'https://cdn.simpleicons.org/typescript',
       'JavaScript': 'https://cdn.simpleicons.org/javascript',
       'HTML': 'https://cdn.simpleicons.org/html5',
       'CSS': 'https://cdn.simpleicons.org/css3',
       'PHP': 'https://cdn.simpleicons.org/php',
       'Laravel': 'https://cdn.simpleicons.org/laravel',
       'Express': 'https://cdn.simpleicons.org/express',
       'Kotlin': 'https://cdn.simpleicons.org/kotlin',
       'Java': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg',
       'Flutter': 'https://cdn.simpleicons.org/flutter',
       'MySQL': 'https://cdn.simpleicons.org/mysql',
       'PostgreSQL': 'https://cdn.simpleicons.org/postgresql',
       'MongoDB': 'https://cdn.simpleicons.org/mongodb',
       'Python': 'https://cdn.simpleicons.org/python',
       'VSCode': 'https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg',
       'Git': 'https://cdn.simpleicons.org/git',
       'GitHub': 'https://cdn.simpleicons.org/github',
       'Laragon': 'https://cdn.simpleicons.org/laragon'
   };

   skillFolders.forEach(folder => {
       folder.addEventListener('click', () => {
           const title = folder.getAttribute('data-title');
           const skills = folder.getAttribute('data-skills').split(', ');
           
           document.getElementById('skill-modal-title').innerText = title + '.exe';
           
           const body = document.getElementById('skill-modal-body');
           body.innerHTML = ''; // Clear previous badges
           
           skills.forEach(skill => {
               const badge = document.createElement('div');
               badge.className = 'flex items-center gap-[8px] border-[2px] border-black bg-white px-[12px] py-[6px] shadow-[2px_2px_0_#000] font-bold text-[14px] hover:-translate-y-1 hover:shadow-[4px_4px_0_var(--color-lime-pulse)] transition-all cursor-default';
               
               const iconUrl = skillIcons[skill];
               if (iconUrl) {
                   const img = document.createElement('img');
                   img.src = iconUrl;
                   img.className = 'w-[16px] h-[16px] object-contain';
                   img.alt = skill + ' logo';
                   img.onerror = () => { img.style.display = 'none'; }; // Hide if icon fails to load
                   badge.appendChild(img);
               }

               const text = document.createElement('span');
               text.innerText = skill;
               badge.appendChild(text);

               body.appendChild(badge);
           });
           
           document.getElementById('skill-modal').classList.remove('hidden');
           document.getElementById('skill-modal').classList.add('flex');
       });
   });

   // Retro Clock Logic
   const clockEl = document.getElementById('retro-clock');
   if (clockEl) {
     const updateClock = () => {
       const now = new Date();
       let hours = now.getHours();
       const minutes = now.getMinutes().toString().padStart(2, '0');
       const ampm = hours >= 12 ? 'PM' : 'AM';
       hours = hours % 12;
       hours = hours ? hours : 12; // the hour '0' should be '12'
       // Using a blinking colon for retro feel
       clockEl.innerHTML = `${hours}<span class="opacity-100 animate-[pulse_1s_ease-in-out_infinite]">:</span>${minutes} ${ampm}`;
     };
     updateClock(); // Initial call
     setInterval(updateClock, 1000);
   }

   // Typing Effect Logic
   const runPanelTypingEffect = (panelId) => {
       const panel = document.getElementById(panelId);
       // Check if already typed so it only happens once
       if (!panel || panel.hasAttribute('data-typed')) return;
       
       panel.setAttribute('data-typed', 'true');
       const targets = panel.querySelectorAll('.type-target');
       
       targets.forEach((target, index) => {
           const text = target.innerText;
           target.innerText = ''; // Clear text immediately so it doesn't flash
           
           // Animation Config
           const TYPE_SPEED = 35; // 35ms per character (slower, more natural)
           const INITIAL_DELAY = 1500; // 1.5 seconds wait before the very first element starts
           const PAUSE_BETWEEN = 500; // 500ms pause between different paragraphs
           
           // Calculate delay based on previous elements length
           let delayMs = 0;
           for(let j = 0; j < index; j++) {
               delayMs += targets[j].innerText.length * TYPE_SPEED + PAUSE_BETWEEN; 
           }
           delayMs += INITIAL_DELAY; // Add the initial delay to all elements
           
           setTimeout(() => {
               let i = 0;
               const typeInterval = setInterval(() => {
                   // Use innerHTML to append a solid block cursor span
                   target.innerHTML = text.substring(0, i + 1) + '<span class="inline-block w-[10px] h-[0.8em] bg-black translate-y-[1px] ml-[4px] animate-pulse"></span>';
                   i++;
                   if (i >= text.length) {
                       clearInterval(typeInterval);
                       // Remove cursor when done
                       target.innerHTML = text;
                   }
               }, TYPE_SPEED);
           }, delayMs);
       });
   };

   // Run typing effect for the default open panel on initial page load
   if (window.innerWidth > 768) {
       runPanelTypingEffect('panel-about');
   } else {
       // On mobile, skip typing effect and show text instantly
       const panel = document.getElementById('panel-about');
       if (panel) panel.setAttribute('data-typed', 'true');
   }
   // Retro Sound Effects (Synthesized)
   const setupRetroSFX = () => {
       let audioCtx = null;
       
       const initAudio = () => {
           if (!audioCtx) {
               audioCtx = new (window.AudioContext || window.webkitAudioContext)();
           }
           if (audioCtx.state === 'suspended') {
               audioCtx.resume();
           }
       };

       const playTone = (freq, type, duration, vol) => {
           if (!audioCtx) return;
           const oscillator = audioCtx.createOscillator();
           const gainNode = audioCtx.createGain();
           
           oscillator.type = type;
           oscillator.frequency.setValueAtTime(freq, audioCtx.currentTime);
           
           // Quick fade out for a percussive sound
           gainNode.gain.setValueAtTime(vol, audioCtx.currentTime);
           gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
           
           oscillator.connect(gainNode);
           gainNode.connect(audioCtx.destination);
           
           oscillator.start();
           oscillator.stop(audioCtx.currentTime + duration);
       };

       const playClick = () => {
           initAudio();
           // Retro Select Sound (two fast ascending tones)
           playTone(440, 'square', 0.1, 0.05); 
           setTimeout(() => playTone(880, 'square', 0.15, 0.05), 50); 
       };

       // Attach listeners to all interactive elements
       const interactables = document.querySelectorAll('a, button, .cursor-pointer, .sidebar-btn, .skill-folder');
       
       interactables.forEach(el => {
           el.addEventListener('click', playClick);
       });
   };
   // Draggable Widget Logic
   const dragHandle = document.getElementById('widget-drag-handle');
   
   if (heroWidget && dragHandle) {
     let isDragging = false;
     let initialX, initialY;
     let xOffset = 0;
     let yOffset = 0;

     dragHandle.addEventListener('mousedown', dragStart);
     document.addEventListener('mouseup', dragEnd);
     document.addEventListener('mousemove', drag);

     function dragStart(e) {
       // Only allow dragging on desktop
       if (window.innerWidth <= 768) return;
       
       initialX = e.clientX - xOffset;
       initialY = e.clientY - yOffset;
       
       if (e.target === dragHandle || dragHandle.contains(e.target)) {
         isDragging = true;
         heroWidget.style.transition = 'none';
         document.body.style.userSelect = 'none'; // Prevent text selection while dragging
       }
     }

     function dragEnd(e) {
       if (!isDragging) return;
       isDragging = false;
       heroWidget.style.transition = '';
       document.body.style.userSelect = '';
     }

     function drag(e) {
       if (isDragging) {
         e.preventDefault();
         const currentX = e.clientX - initialX;
         const currentY = e.clientY - initialY;
         
         xOffset = currentX;
         yOffset = currentY;
         
         heroWidget.style.transform = `translate(${currentX}px, ${currentY}px)`;
       }
     }
   }

   setupRetroSFX();

</script>

