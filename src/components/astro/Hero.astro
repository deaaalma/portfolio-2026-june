---
import Badge from './Badge.astro';
import Button from './Button.astro';
---

<section class="relative w-full bg-gradient-to-b from-[#7dd3fc] via-[#bae6fd] to-[#e0f2fe] pt-[180px] pb-[120px] overflow-visible">
  <!-- Wavy Divider Bottom (if any, but image doesn't show bottom edge, assuming standard wavy) -->
  <div class="absolute bottom-[-1px] left-0 w-full overflow-hidden leading-[0] z-20">
    <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.9,188.94,99.73,235.17,86.85,280.4,70.93,321.39,56.44Z" fill="var(--color-paper-white)"></path>
    </svg>
  </div>

  <!-- Decorative Clouds with White Fill -->
  <svg class="absolute top-[20%] left-[8%] w-[120px] h-[80px] -rotate-2" viewBox="0 0 100 60" fill="var(--color-paper-white)" stroke="var(--color-carbon-black)" stroke-width="1.5">
    <path d="M25 45 C15 45 10 38 12 30 C15 20 25 15 35 18 C40 8 60 5 70 15 C82 12 90 20 88 32 C95 38 90 45 80 45 Z" />
  </svg>
  <svg class="absolute top-[40%] left-[15%] w-[80px] h-[50px] rotate-3" viewBox="0 0 100 60" fill="var(--color-paper-white)" stroke="var(--color-carbon-black)" stroke-width="1.5">
    <path d="M25 45 C15 45 10 38 12 30 C15 20 25 15 35 18 C40 8 60 5 70 15 C82 12 90 20 88 32 C95 38 90 45 80 45 Z" />
  </svg>
  <svg class="absolute top-[18%] right-[10%] w-[150px] h-[90px] rotate-1" viewBox="0 0 100 60" fill="var(--color-paper-white)" stroke="var(--color-carbon-black)" stroke-width="1.5">
    <path d="M25 45 C15 45 10 38 12 30 C15 20 25 15 35 18 C40 8 60 5 70 15 C82 12 90 20 88 32 C95 38 90 45 80 45 Z" />
  </svg>
  <svg class="absolute top-[35%] right-[12%] w-[100px] h-[60px] -rotate-3" viewBox="0 0 100 60" fill="var(--color-paper-white)" stroke="var(--color-carbon-black)" stroke-width="1.5">
    <path d="M25 45 C15 45 10 38 12 30 C15 20 25 15 35 18 C40 8 60 5 70 15 C82 12 90 20 88 32 C95 38 90 45 80 45 Z" />
  </svg>

  <div class="relative max-w-[1200px] mx-auto px-[24px] flex flex-col items-center text-center z-10">
    <Badge class="mb-[24px]">
      <span class="mr-[6px] flex items-center gap-[4px]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-lime-pulse)" stroke="var(--color-carbon-black)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 12v-3a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v3"></path>
            <path d="M20 12v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3"></path>
        </svg>
        The Knowledge Layer for AI
      </span>
    </Badge>
    
    <h1 class="text-[var(--text-display-xl)] font-bold leading-[var(--leading-display-xl)] tracking-[var(--tracking-display-xl)] max-w-[900px] mb-[24px]">
      Your AI isn't up to date on your product.<br/>Brainfish fixes that.
    </h1>
    
    <p class="text-[var(--text-subheading)] leading-[var(--leading-subheading)] text-[var(--color-carbon-black)] font-medium max-w-[650px] mb-[40px]">
      Brainfish builds living product knowledge, delivered personally to every customer and agent. Most tools forget what you ship. Brainfish doesn't.
    </p>
    
    <div class="flex flex-wrap justify-center gap-[16px] mb-[80px]">
      <Button variant="primary" class="gap-[8px]">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        Book Demo
      </Button>
      <a href="#" class="inline-flex items-center justify-center border border-[var(--color-carbon-black)] bg-[var(--color-paper-white)] rounded-[var(--radius-buttons)] px-[24px] py-[10px] text-[var(--text-body)] font-medium text-[var(--color-carbon-black)] shadow-[var(--shadow-subtle)] gap-[8px]">
        Join Webinar
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
      </a>
    </div>

    <!-- Product Mockup Card -->
    <div class="relative w-full max-w-[960px] h-[500px] bg-[var(--color-fog)] border border-[var(--color-carbon-black)] rounded-[var(--radius-cards-lg)] shadow-[var(--shadow-subtle-4)] overflow-hidden flex flex-col mx-auto z-10 text-left">
      <!-- Browser Chrome / Top Bar -->
      <div class="flex items-center justify-between px-[16px] py-[12px] border-b border-[var(--color-carbon-black)] bg-[var(--color-paper-white)]">
        <div class="flex items-center gap-[8px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-lime-pulse)" stroke="var(--color-carbon-black)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
            <span class="font-bold text-[14px]">Brainfish</span>
        </div>
        <div class="flex items-center gap-[12px]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-carbon-black)" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <div class="w-[24px] h-[24px] bg-[var(--color-slate)] rounded-full border border-[var(--color-carbon-black)]"></div>
        </div>
      </div>

      <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar -->
        <div class="w-[240px] border-r border-[var(--color-carbon-black)] bg-[var(--color-paper-white)] flex flex-col p-[16px]">
          <div class="flex flex-col gap-[8px] mb-[24px]">
            <div class="flex items-center gap-[8px] bg-[var(--color-lime-pulse)] px-[12px] py-[8px] rounded-[var(--radius-md)] border border-[var(--color-carbon-black)] font-bold text-[14px]">
                Knowledge
            </div>
            <div class="flex items-center gap-[8px] px-[12px] py-[8px] text-[var(--color-slate)] font-medium text-[14px]">
                Distribution
            </div>
            <div class="flex items-center gap-[8px] px-[12px] py-[8px] text-[var(--color-slate)] font-medium text-[14px]">
                Analytics
            </div>
          </div>
          
          <div class="relative mb-[16px]">
            <input type="text" placeholder="Find an Article" class="w-full border border-[var(--color-carbon-black)] rounded-[var(--radius-md)] px-[12px] py-[6px] text-[12px] bg-[var(--color-paper-white)]" disabled />
          </div>

          <div class="flex flex-col gap-[4px] text-[12px] font-medium text-[var(--color-carbon-black)]">
            <div class="px-[8px] py-[4px] text-[var(--color-slate)]">Marketing Blog Posts</div>
            <div class="px-[8px] py-[4px] bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)] rounded-[4px] opacity-20">Getting Started</div>
            <div class="px-[8px] py-[4px]">Onboarding</div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 bg-[var(--color-fog)] p-[32px] relative overflow-hidden">
            <div class="flex items-center justify-between mb-[24px]">
                <h2 class="text-[24px] font-bold">Getting Started</h2>
                <div class="flex items-center gap-[8px]">
                    <span class="text-[12px] text-[var(--color-slate)]">4h ago</span>
                    <button class="border border-[var(--color-carbon-black)] px-[8px] py-[4px] rounded-[4px] text-[12px] bg-[var(--color-paper-white)] shadow-[var(--shadow-subtle-3)]">Edit</button>
                    <button class="border border-[var(--color-carbon-black)] px-[8px] py-[4px] rounded-[4px] text-[12px] bg-[var(--color-lime-pulse)] shadow-[var(--shadow-subtle-3)] font-medium">Upload Knowledge</button>
                </div>
            </div>
            
            <h3 class="text-[18px] font-bold mb-[12px]">Introduction</h3>
            <p class="text-[14px] leading-relaxed mb-[24px] text-[var(--color-slate)] max-w-[500px]">
                Brainfish is an AI platform for the full product lifecycle that can onboard, train, engage, and support users using artificial intelligence. In this article, we will walk you through some of the key features of Brainfish and how to get started with it.
            </p>

            <h3 class="text-[18px] font-bold mb-[12px]">Features</h3>
            <p class="text-[14px] leading-relaxed mb-[24px] text-[var(--color-slate)] max-w-[500px]">
                1. AI-Powered Knowledge Base<br/>
                2. Automated User Onboarding
            </p>
            
            <!-- Modal Overlay -->
            <div class="absolute inset-0 bg-black/5 flex items-center justify-center p-[24px]">
                <div class="bg-[var(--color-paper-white)] border border-[var(--color-carbon-black)] rounded-[var(--radius-lg)] p-[24px] shadow-[var(--shadow-subtle-2)] w-full max-w-[400px] mt-[100px]">
                    <div class="flex items-center justify-between mb-[16px] border-b border-[var(--color-carbon-black)] pb-[12px]">
                        <div class="flex gap-[16px] text-[14px] font-bold">
                            <span class="text-[var(--color-carbon-black)] flex items-center gap-[4px]"><span class="w-[8px] h-[8px] rounded-full bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)]"></span> File upload</span>
                            <span class="text-[var(--color-slate)]">Weblink</span>
                            <span class="text-[var(--color-slate)]">Record</span>
                        </div>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </div>
                    <div class="border border-dashed border-[var(--color-carbon-black)] rounded-[4px] p-[32px] text-center text-[12px] text-[var(--color-slate)]">
                        Drag and drop your file here<br/>
                        or click to browse
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</section>
