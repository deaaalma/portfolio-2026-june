---
import Button from './Button.astro';
import { Image } from 'astro:assets';
import logoHd from '../../assets/images/logo-hd.png';

export interface Props {
  hiddenOnLoad?: boolean;
}

const { hiddenOnLoad = false } = Astro.props;

const headerClasses = [
  "fixed top-[24px] left-1/2 -translate-x-1/2 w-[calc(100%-48px)] max-w-[900px] z-50 transition-all duration-700",
  hiddenOnLoad ? "-translate-y-[150%] opacity-0 pointer-events-none" : ""
].filter(Boolean).join(" ");
---
<header id="main-navbar" class={headerClasses}>
  <nav class="flex items-center justify-between bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-full px-[16px] py-[12px] shadow-[4px_4px_0_#000]">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-[8px] pl-[12px] relative z-[60]">
      <Image src={logoHd} alt="Love Logo HD" width={32} class="w-[32px] h-[32px] object-contain drop-shadow-[1px_1px_0_#000]" />
      <span class="text-[20px] font-bold text-[var(--color-carbon-black)] tracking-tight">Dea Alma</span>
    </a>
    
    <!-- Right Side (Desktop Links & CTAs) -->
    <div class="hidden md:flex items-center gap-[36px]">
      <!-- Links -->
      <div class="flex items-center gap-[36px]">
        <a href="/#about" class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">About</a>
        <a href="/#experience" class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">Experience</a>
        <a href={Astro.url.pathname.includes('/projects') ? '#' : '/#projects'} class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">Projects</a>
      </div>

      <!-- CTAs -->
      <div class="flex items-center gap-[12px]">
        <button onclick="document.getElementById('hire-me-modal').classList.remove('hidden'); document.getElementById('hire-me-modal').classList.add('flex');" class="flex items-center gap-[8px] text-[15px] font-bold text-[var(--color-carbon-black)] border-[1.5px] border-[var(--color-carbon-black)] rounded-full px-[20px] py-[8px] bg-[var(--color-lime-pulse)] shadow-[2px_2px_0_#000] hover:brightness-95 transition-all">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Let's Talk
        </button>
      </div>
    </div>

    <!-- Mobile Hamburger Button -->
    <button id="mobile-menu-btn" class="md:hidden relative z-[60] p-2 flex flex-col gap-1.5 justify-center items-center mr-2">
        <span class="w-[24px] h-[3px] bg-black block transition-all duration-300 origin-center"></span>
        <span class="w-[24px] h-[3px] bg-black block transition-all duration-300 origin-center"></span>
        <span class="w-[24px] h-[3px] bg-black block transition-all duration-300 origin-center"></span>
    </button>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu-dropdown" class="absolute top-[calc(100%+12px)] left-0 w-full bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-[24px] p-[20px] shadow-[4px_4px_0_#000] flex flex-col gap-[12px] md:hidden opacity-0 pointer-events-none translate-y-[-10px] transition-all duration-300 z-[40] before:content-[''] before:absolute before:top-[-10px] before:right-[32px] before:w-0 before:h-0 before:border-l-[10px] before:border-r-[10px] before:border-b-[10px] before:border-transparent before:border-b-[var(--color-carbon-black)]">
      <!-- Triangle Pointer inner -->
      <div class="absolute top-[-7px] right-[32px] w-0 h-0 border-l-[10px] border-r-[10px] border-b-[10px] border-transparent border-b-[var(--color-paper-white)] z-[41]"></div>
      
      <a href="/#about" class="mobile-link text-[18px] font-bold text-[var(--color-carbon-black)] hover:text-black hover:pl-[4px] transition-all text-left border-b border-dashed border-gray-300 pb-3 pt-1">About</a>
      <a href="/#experience" class="mobile-link text-[18px] font-bold text-[var(--color-carbon-black)] hover:text-black hover:pl-[4px] transition-all text-left border-b border-dashed border-gray-300 pb-3 pt-2">Experience</a>
      <a href={Astro.url.pathname.includes('/projects') ? '#' : '/#projects'} class="mobile-link text-[18px] font-bold text-[var(--color-carbon-black)] hover:text-black hover:pl-[4px] transition-all text-left border-b border-dashed border-gray-300 pb-3 pt-2">Projects</a>
      
      <button onclick="document.getElementById('mobile-menu-btn').click(); document.getElementById('hire-me-modal').classList.remove('hidden'); document.getElementById('hire-me-modal').classList.add('flex');" class="mt-[8px] flex items-center justify-center gap-[8px] text-[16px] font-bold text-black border-[2px] border-black rounded-full px-[24px] py-[10px] bg-[var(--color-lime-pulse)] shadow-[2px_2px_0_#000] hover:translate-y-[2px] hover:shadow-[1px_1px_0_#000] transition-all w-full">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Let's Talk!
      </button>
  </div>
</header>



<script>
  document.addEventListener('astro:page-load', () => {
    // Mobile Menu Logic
    const menuBtn = document.getElementById('mobile-menu-btn');
    const dropdown = document.getElementById('mobile-menu-dropdown');
    const lines = menuBtn?.querySelectorAll('span');
    const links = document.querySelectorAll('.mobile-link');

    let isMenuOpen = false;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        dropdown?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
        dropdown?.classList.add('opacity-100', 'translate-y-0');
        // Animate hamburger to X
        if(lines && lines.length === 3) {
            lines[0].style.transform = 'translateY(9px) rotate(45deg)';
            lines[1].style.opacity = '0';
            lines[2].style.transform = 'translateY(-9px) rotate(-45deg)';
        }
      } else {
        dropdown?.classList.remove('opacity-100', 'translate-y-0');
        dropdown?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-[-10px]');
        // Animate X to hamburger
        if(lines && lines.length === 3) {
            lines[0].style.transform = 'none';
            lines[1].style.opacity = '1';
            lines[2].style.transform = 'none';
        }
      }
    }

    menuBtn?.addEventListener('click', toggleMenu);

    // Close menu when a link is clicked
    links.forEach(link => {
      link.addEventListener('click', () => {
        if(isMenuOpen) toggleMenu();
      });
    });
  });
</script>
