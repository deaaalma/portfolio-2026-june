---
import '../styles/global.css';
import BgmPlayer from '../components/astro/BgmPlayer.astro';
import { ClientRouter } from 'astro:transitions';
import { Image } from 'astro:assets';
import gmailPixel from '../assets/images/gmail-pixel.png';
import linkedinPixel from '../assets/images/linkedin-pixel.png';
import whatsappPixel from '../assets/images/whatsapp-pixel.png';
import githubPixel from '../assets/images/github-pixel.png';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfolio of Putu Ayu Deanisa Alma Putri — Information Technology student and Web Developer based in Bali. Explore my projects, experience, and skills." />
		<meta name="keywords" content="Putu Ayu Deanisa Alma Putri, Dea Alma, Portfolio, Web Developer, IT Student, Udayana University, Bali, Frontend Developer, Web Development" />
		<meta name="author" content="Putu Ayu Deanisa Alma Putri" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://portfolio-2026-june.vercel.app/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Portfolio of Putu Ayu Deanisa Alma Putri — Information Technology student and Web Developer based in Bali." />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://portfolio-2026-june.vercel.app/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="Portfolio of Putu Ayu Deanisa Alma Putri — Information Technology student and Web Developer based in Bali." />

		<title>{title}</title>
		<!-- Runs synchronously before any HTML renders: skip intro if already seen this session -->
		<script is:inline>
			if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem('portfolio_intro_done') === '1') {
				document.documentElement.classList.add('no-intro');
			}
		</script>
		<style>
			/* Applied instantly (before JS bundles load) to hide intro elements for returning visitors */
			html.no-intro #press-start-btn,
			html.no-intro #hello-world-title,
			html.no-intro #retro-hud { display: none !important; }
			html.no-intro #hero-widget {
				opacity: 1 !important;
				transform: none !important;
				pointer-events: auto !important;
				position: relative !important;
				top: auto !important;
				margin-top: 20px;
			}
			html.no-intro #hero-main-container { margin-top: 0 !important; }
			html.no-intro #main-navbar { opacity: 1 !important; transform: none !important; pointer-events: auto !important; }
			html.no-intro #main-content { display: block !important; opacity: 1 !important; }
			html.no-intro #hero-divider { opacity: 1 !important; }
			html.no-intro #crt-overlay { display: none !important; }
		</style>
	</head>
	<body>
		<slot />
		
		<!-- Hire Me Modal (Global) -->
		<div id="hire-me-modal" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center">
			<!-- Backdrop -->
			<div id="hire-me-backdrop" onclick="document.getElementById('hire-me-modal').classList.add('hidden'); document.getElementById('hire-me-modal').classList.remove('flex');" class="absolute inset-0 bg-black/40 backdrop-blur-[2px] cursor-pointer"></div>
			
			<!-- Modal Window -->
			<div class="relative bg-[var(--color-fog)] w-[90%] max-w-[500px] border-[3px] border-black shadow-[8px_8px_0_#000] flex flex-col z-10 animate-[float_0.5s_ease-out_forwards]">
				<!-- Modal Header -->
				<div class="bg-[var(--color-paper-white)] border-b-[3px] border-black px-[16px] py-[10px] flex justify-between items-center">
					<div class="flex items-center gap-[8px]">
						<span class="w-[12px] h-[12px] rounded-full bg-[#E52521] border-[1.5px] border-black"></span>
						<span class="w-[12px] h-[12px] rounded-full bg-[#FBD000] border-[1.5px] border-black"></span>
						<span class="w-[12px] h-[12px] rounded-full bg-[#00C853] border-[1.5px] border-black"></span>
					</div>
					<button id="close-modal-btn" onclick="document.getElementById('hire-me-modal').classList.add('hidden'); document.getElementById('hire-me-modal').classList.remove('flex');" class="w-[24px] h-[24px] bg-[#E52521] border-[2px] border-black flex items-center justify-center hover:brightness-110 active:translate-y-[2px] active:shadow-none shadow-[2px_2px_0_#000] transition-all">
						<span class="text-white font-bold text-[12px] leading-none mb-[2px]">x</span>
					</button>
				</div>
				
				<!-- Modal Body -->
				<div class="p-[24px] flex flex-col items-center gap-[8px]">
					<p class="text-[14px] font-medium text-[var(--color-slate)] text-center">Let's build something awesome together! Reach out to me via:</p>
					
					<div class="flex flex-row flex-wrap gap-[16px] justify-center mt-0 items-center">
						<!-- Email -->
						<a href="mailto:hopegekdea@gmail.com" target="_blank" class="w-[96px] h-[96px] flex items-center justify-center hover:-translate-y-2 transition-transform cursor-pointer group">
							<Image src={gmailPixel} alt="Email Logo" width={72} height={72} class="w-[72px] h-[72px] object-contain group-hover:scale-110 transition-transform drop-shadow-[4px_4px_0_rgba(0,0,0,0.15)]" style="image-rendering: pixelated;" />
						</a>
						
						<!-- LinkedIn -->
						<a href="https://www.linkedin.com/in/putu-ayu-deanisa-alma-putri-ab495731b/" target="_blank" class="w-[96px] h-[96px] flex items-center justify-center hover:-translate-y-2 transition-transform cursor-pointer group">
							<Image src={linkedinPixel} alt="LinkedIn Logo" width={88} height={88} class="w-[88px] h-[88px] object-contain group-hover:scale-110 transition-transform drop-shadow-[4px_4px_0_rgba(0,0,0,0.15)]" style="image-rendering: pixelated;" />
						</a>
						
						<!-- WhatsApp -->
						<a href="https://wa.me/6281339925118" target="_blank" class="w-[96px] h-[96px] flex items-center justify-center hover:-translate-y-2 transition-transform cursor-pointer group">
							<Image src={whatsappPixel} alt="WhatsApp Logo" width={88} height={88} class="w-[88px] h-[88px] object-contain group-hover:scale-110 transition-transform drop-shadow-[4px_4px_0_rgba(0,0,0,0.15)]" style="image-rendering: pixelated;" />
						</a>
						
						<!-- GitHub -->
						<a href="https://github.com/deaaalma" target="_blank" class="w-[96px] h-[96px] flex items-center justify-center hover:-translate-y-2 transition-transform cursor-pointer group">
							<Image src={githubPixel} alt="GitHub Logo" width={84} height={84} class="w-[84px] h-[84px] object-contain group-hover:scale-110 transition-transform drop-shadow-[4px_4px_0_rgba(0,0,0,0.15)]" style="image-rendering: pixelated;" />
						</a>
					</div>
				</div>
			</div>
		</div>

		<BgmPlayer />
		
		<script>
			import Lenis from '@studio-freight/lenis';
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);

			let lenis;

			document.addEventListener('astro:page-load', () => {
				if (!lenis) {
					lenis = new Lenis({
						autoRaf: true,
					});

					lenis.on('scroll', ScrollTrigger.update);

					gsap.ticker.add((time) => {
						lenis.raf(time * 1000);
					});

					gsap.ticker.lagSmoothing(0);
				}

				ScrollTrigger.refresh();

				// Handle smooth scrolling for anchor links
				document.querySelectorAll('a[href^="/#"], a[href^="#"]').forEach(anchor => {
					// Remove existing listener to prevent duplicates
					const newAnchor = anchor.cloneNode(true);
					anchor.parentNode.replaceChild(newAnchor, anchor);
					
					newAnchor.addEventListener('click', function (e) {
						const href = this.getAttribute('href');
						const targetId = href.substring(href.indexOf('#'));
						if (targetId === '#') return;
						
						// Only smooth scroll if we are currently on the homepage
						if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
							const targetElement = document.querySelector(targetId);
							if (targetElement) {
								e.preventDefault();
								lenis.scrollTo(targetElement, {
									offset: -80, // offset for navbar
									duration: 1.2
								});
							}
						}
					});
				});
			});
		</script>
	</body>
</html>
