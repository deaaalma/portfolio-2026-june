---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Hero from '../components/astro/Hero.astro';
import Badge from '../components/astro/Badge.astro';
import Button from '../components/astro/Button.astro';
---

<Layout title="Brainfish Portfolio">
  <Navbar />
  
  <main>
    <Hero />

    <!-- Content below Hero is hidden until Start is pressed -->
    <div id="main-content" class="hidden opacity-0 transition-opacity duration-1000">

    <!-- Logo Strip White Band (Before Green Section) -->
    <section class="w-full bg-[var(--color-paper-white)] py-[60px] flex items-center justify-center gap-[60px]">
        <span class="font-bold text-[24px] tracking-tighter">SMOKEBALL</span>
        <span class="font-bold text-[24px] tracking-tighter">madpaws</span>
    </section>

    <!-- The Problem / The Solution Section -->
    <section class="relative w-full bg-gradient-to-b from-[#86efac] via-[#bbf7d0] to-[#dcfce7] pt-[140px] pb-[160px] overflow-hidden">
      <!-- Wavy divider from LogoStrip (white) to this green section -->
      <div class="absolute top-[-1px] left-0 w-full overflow-hidden leading-[0] rotate-180">
        <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.9,188.94,99.73,235.17,86.85,280.4,70.93,321.39,56.44Z" fill="var(--color-paper-white)"></path>
        </svg>
      </div>

      <div class="relative max-w-[1200px] mx-auto px-[24px] flex flex-col items-center text-center z-10">
        <Badge class="mb-[24px]">
          <span class="mr-[6px] text-orange-500">✨</span>
          The Problem
        </Badge>
        
        <h2 class="text-[var(--text-display-xl)] font-bold leading-[1.1] tracking-[var(--tracking-display-xl)] max-w-[900px] mb-[80px]">
          Knowledge sprawl is holding your AI agents back from doing their best work.
        </h2>

        <!-- Floating app icons placeholder -->
        <div class="absolute inset-0 w-full h-full pointer-events-none">
            <div class="absolute top-[20%] left-[10%] w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000] rotate-12 flex items-center justify-center font-bold text-blue-500">S</div>
            <div class="absolute top-[10%] right-[20%] w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000] -rotate-12 flex items-center justify-center font-bold text-blue-600">N</div>
            <div class="absolute top-[50%] left-[5%] w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000] rotate-6 flex items-center justify-center font-bold text-orange-500">H</div>
            <div class="absolute top-[40%] right-[10%] w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000] -rotate-6 flex items-center justify-center font-bold text-black">G</div>
        </div>

        <!-- The Solution Card -->
        <div class="w-full bg-[var(--color-paper-white)] border border-[var(--color-carbon-black)] rounded-[var(--radius-cards-lg)] shadow-[var(--shadow-subtle-4)] p-[40px] md:p-[80px] flex flex-col items-center mt-[40px] z-10 relative">
          <Badge class="mb-[24px]">
            <span class="mr-[6px] text-orange-500">✨</span>
            The Solution
          </Badge>
          <h3 class="text-[var(--text-display)] font-bold tracking-[var(--tracking-display)] mb-[16px]">Brainfish aligns AI with your product</h3>
          <p class="text-[18px] text-[var(--color-carbon-black)] font-medium max-w-[700px] mb-[60px]">
            Turn scattered docs, calls, and systems into a continuously updated knowledge layer - intelligently personalized by account and delivered across every channel.
          </p>
          
          <!-- Mockup inner area -->
          <div class="w-full grid grid-cols-3 gap-[16px]">
            <div class="h-[120px] bg-[var(--color-lilac-mist)] rounded-[8px] border-2 border-dashed border-[var(--color-carbon-black)]"></div>
            <div class="h-[120px] bg-[var(--color-buttercream)] rounded-[8px] border-2 border-dashed border-[var(--color-carbon-black)] relative overflow-hidden flex items-center justify-center"><div class="bg-[var(--color-buttercream)] border border-black px-[12px] py-[4px] rounded-[4px] text-[12px] font-bold shadow-[1px_1px_0_#000]">Subscription</div></div>
            <div class="h-[120px] bg-[var(--color-mint-wash)] rounded-[8px] border-2 border-dashed border-[var(--color-carbon-black)] flex flex-col items-center justify-center gap-[8px]">
                <div class="bg-[var(--color-mint-wash)] border border-black px-[16px] py-[6px] rounded-[100px] text-[12px] font-bold shadow-[2px_2px_0_#000]">Slack</div>
                <div class="bg-[var(--color-mint-wash)] border border-black px-[16px] py-[6px] rounded-[100px] text-[12px] font-bold shadow-[2px_2px_0_#000]">Help Centers</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Knowledge that builds itself Section -->
    <section class="relative w-full bg-[var(--color-paper-white)] pt-[160px] pb-[160px]">
      <!-- Wavy divider green to white -->
      <div class="absolute top-[-1px] left-0 w-full overflow-hidden leading-[0] rotate-180">
        <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.9,188.94,99.73,235.17,86.85,280.4,70.93,321.39,56.44Z" fill="#b9f0c0"></path>
        </svg>
      </div>

      <div class="max-w-[1200px] mx-auto px-[24px]">
        <div class="flex flex-col items-start max-w-[650px] mb-[60px]">
          <Badge class="mb-[24px]">
            <span class="mr-[6px] text-blue-500">✨</span>
            Knowledge Layer
          </Badge>
          <h2 class="text-[var(--text-display)] font-bold leading-[1.1] tracking-[var(--tracking-display)] mb-[16px]">
            Knowledge that builds itself
          </h2>
          <p class="text-[18px] leading-[1.5] text-[var(--color-carbon-black)] font-medium">
            Stop letting product changes turn into outdated docs and wrong answers. Every call, session, and system update automatically feeds your knowledge layer - so your teams and agents always work from what's actually live.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-[40px]">
          <!-- Card 1 -->
          <div class="flex flex-col">
            <div class="w-full h-[320px] bg-[#e0f2fe] rounded-[var(--radius-cards-lg)] mb-[24px] border border-[var(--color-carbon-black)] flex flex-col items-center justify-center relative overflow-hidden">
               <div class="px-[16px] py-[8px] bg-[#3b82f6] text-white rounded-[100px] border border-[var(--color-carbon-black)] shadow-[var(--shadow-subtle-2)] text-[14px] font-bold z-10 mt-[80px]">✨ Knowledge Discoveries</div>
               <div class="absolute inset-0 flex flex-wrap gap-[16px] items-center justify-center p-[40px] opacity-80 pointer-events-none">
                 <div class="w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000]"></div>
                 <div class="w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000]"></div>
                 <div class="w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000]"></div>
                 <div class="w-[40px] h-[40px] bg-white border border-black rounded-[8px] shadow-[2px_2px_0_#000]"></div>
               </div>
            </div>
            <h3 class="text-[20px] font-bold mb-[8px]">Generate articles from any source</h3>
            <p class="text-[16px] font-medium text-[var(--color-carbon-black)] opacity-80">Build structured content from any call, video, doc, or third-party source.</p>
          </div>

          <!-- Card 2 -->
          <div class="flex flex-col">
            <div class="w-full h-[320px] bg-[#e0f2fe] rounded-[var(--radius-cards-lg)] mb-[24px] border border-[var(--color-carbon-black)] p-[32px] relative overflow-hidden flex items-center justify-end">
                <!-- UI Mockup Graphic -->
                <div class="w-[280px] bg-[var(--color-paper-white)] rounded-[12px] border border-[var(--color-carbon-black)] shadow-[var(--shadow-subtle-2)] p-[20px]">
                    <div class="text-[10px] font-bold text-[var(--color-slate)] mb-[4px] uppercase">1 DAY AGO FROM</div>
                    <div class="text-[12px] font-bold mb-[12px]">Session Recording</div>
                    <div class="text-[12px] mb-[20px] font-medium leading-relaxed">Add context about an easy to use admin interface that helps customers manage onboarding staff</div>
                    <div class="flex gap-[8px]">
                        <div class="w-[28px] h-[28px] bg-[#4ade80] rounded-[6px] border border-[var(--color-carbon-black)] flex items-center justify-center shadow-[1px_1px_0_#000]">✓</div>
                        <div class="w-[28px] h-[28px] bg-[#f87171] rounded-[6px] border border-[var(--color-carbon-black)] flex items-center justify-center shadow-[1px_1px_0_#000]">×</div>
                    </div>
                </div>
            </div>
            <h3 class="text-[20px] font-bold mb-[8px]">Catch every product change</h3>
            <p class="text-[16px] font-medium text-[var(--color-carbon-black)] opacity-80">Flag outdated knowledge for review the moment you ship something.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="relative w-full bg-[var(--color-cobalt-field)] pt-[160px] pb-[160px] overflow-hidden">
      <!-- Wavy divider white to blue -->
      <div class="absolute top-[-1px] left-0 w-full overflow-hidden leading-[0] rotate-180">
        <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,115.9,188.94,99.73,235.17,86.85,280.4,70.93,321.39,56.44Z" fill="var(--color-paper-white)"></path>
        </svg>
      </div>

      <!-- Yellow Quotes -->
      <div class="absolute top-[30%] right-[15%] text-[140px] leading-none text-[#fbbf25] font-black rotate-[10deg] drop-shadow-[4px_4px_0_rgba(0,0,0,1)]" style="-webkit-text-stroke: 3px black;">
        ”
      </div>

      <!-- Floating Fish -->
      <svg class="absolute top-[25%] left-[10%] w-[32px] h-[32px] text-[#fbbf25] rotate-[-15deg]" viewBox="0 0 24 24" fill="currentColor" stroke="black" stroke-width="2"><path d="M4 12v-3a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v3"></path><path d="M20 12v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3"></path></svg>
      <svg class="absolute bottom-[20%] right-[10%] w-[24px] h-[24px] text-[#a3e635] rotate-[15deg]" viewBox="0 0 24 24" fill="currentColor" stroke="black" stroke-width="2"><path d="M4 12v-3a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v3"></path><path d="M20 12v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3"></path></svg>

      <div class="relative max-w-[1200px] mx-auto px-[24px] flex flex-col items-center z-10">
        <Badge class="mb-[32px]">
          <span class="mr-[6px] text-orange-500">✨</span>
          Brainfish works
        </Badge>
        
        <h2 class="text-[var(--text-display-xl)] text-[var(--color-paper-white)] font-bold leading-[1.1] tracking-[var(--tracking-display-xl)] mb-[100px] text-center max-w-[800px]">
          The new way to enable users.
        </h2>

        <div class="flex flex-col md:flex-row gap-[40px] md:gap-[60px] items-start justify-center w-full">
          <!-- Testimonial 1 -->
          <div class="bg-[var(--color-paper-white)] border border-[var(--color-carbon-black)] rounded-[var(--radius-cards-lg)] p-[32px] shadow-[var(--shadow-subtle-4)] max-w-[420px] -rotate-3 hover:rotate-0 transition-transform origin-bottom-right">
            <div class="flex items-center gap-[8px] mb-[24px]">
                <div class="w-[24px] h-[24px] bg-red-100 rounded-full border border-[var(--color-carbon-black)]"></div>
                <span class="font-bold text-[18px] text-[#ef4444]">Circular</span>
            </div>
            <p class="text-[18px] leading-[1.5] mb-[32px] font-medium text-[var(--color-carbon-black)]">
              "All the other options needed us to spend a lot of time onboarding — time we already didn't have!"
            </p>
            <div class="flex items-center gap-[12px] mb-[32px]">
              <div class="w-[48px] h-[48px] bg-gray-200 rounded-full border border-[var(--color-carbon-black)]"></div>
              <div class="flex flex-col">
                <span class="font-bold text-[16px]">Yaniv Bernstein</span>
                <span class="text-[14px] font-medium text-[var(--color-slate)]">COO & Co-Founder</span>
              </div>
            </div>
            <div class="flex gap-[16px] mb-[32px]">
                <div class="flex-1 bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)] rounded-[8px] p-[16px] shadow-[1px_1px_0_#000]">
                    <div class="text-[28px] font-black mb-[4px] tracking-tight">+20%</div>
                    <div class="text-[12px] leading-tight font-medium">Saved hours per week</div>
                </div>
                <div class="flex-1 bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)] rounded-[8px] p-[16px] shadow-[1px_1px_0_#000]">
                    <div class="text-[28px] font-black mb-[4px] tracking-tight">+275%</div>
                    <div class="text-[12px] leading-tight font-medium">Bottom line ROI</div>
                </div>
            </div>
            <a href="#" class="inline-flex w-full items-center justify-center border border-[var(--color-carbon-black)] bg-[var(--color-paper-white)] rounded-[var(--radius-buttons)] px-[24px] py-[12px] text-[16px] font-medium text-[var(--color-carbon-black)] shadow-[var(--shadow-subtle)] gap-[8px]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
              Read Case Study
            </a>
          </div>

          <!-- Testimonial 2 -->
          <div class="bg-[var(--color-paper-white)] border border-[var(--color-carbon-black)] rounded-[var(--radius-cards-lg)] p-[32px] shadow-[var(--shadow-subtle-4)] max-w-[420px] rotate-3 hover:rotate-0 transition-transform origin-bottom-left mt-[80px]">
            <div class="flex items-center gap-[8px] mb-[24px]">
                <div class="w-[24px] h-[24px] bg-purple-100 rounded-full border border-[var(--color-carbon-black)]"></div>
                <span class="font-bold text-[18px] text-[#8b5cf6]">CAREMASTER</span>
            </div>
            <p class="text-[18px] leading-[1.5] mb-[32px] font-medium text-[var(--color-carbon-black)]">
              "Brainfish freed our Customer Care team from handling routine queries so they could focus on solving the complex challenges our community faces that truly required human expertise."
            </p>
            <div class="flex items-center gap-[12px] mb-[32px]">
              <div class="w-[48px] h-[48px] bg-gray-200 rounded-full border border-[var(--color-carbon-black)]"></div>
              <div class="flex flex-col">
                <span class="font-bold text-[16px]">Elisha Anderton</span>
                <span class="text-[14px] font-medium text-[var(--color-slate)]">COO at CareMaster</span>
              </div>
            </div>
            <div class="flex gap-[16px] mb-[32px]">
                <div class="flex-1 bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)] rounded-[8px] p-[16px] shadow-[1px_1px_0_#000]">
                    <div class="text-[28px] font-black mb-[4px] tracking-tight">+76%</div>
                    <div class="text-[12px] leading-tight font-medium">Self-service resolution</div>
                </div>
                <div class="flex-1 bg-[var(--color-lime-pulse)] border border-[var(--color-carbon-black)] rounded-[8px] p-[16px] shadow-[1px_1px_0_#000]">
                    <div class="text-[28px] font-black mb-[4px] tracking-tight">+23%</div>
                    <div class="text-[12px] leading-tight font-medium">Growth in user base</div>
                </div>
            </div>
            <a href="#" class="inline-flex w-full items-center justify-center border border-[var(--color-carbon-black)] bg-[var(--color-paper-white)] rounded-[var(--radius-buttons)] px-[24px] py-[12px] text-[16px] font-medium text-[var(--color-carbon-black)] shadow-[var(--shadow-subtle)] gap-[8px]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
              Read Case Study
            </a>
          </div>
        </div>
      </div>
    </section>
    </div>
  </main>
</Layout>
