---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Hero from '../components/astro/Hero.astro';
import Badge from '../components/astro/Badge.astro';
import Button from '../components/astro/Button.astro';
---

<Layout title="Brainfish Portfolio">
  <Navbar />
  
  <main>
    <Hero />

    <!-- Content below Hero is hidden until Start is pressed -->
    <div id="main-content" class="hidden opacity-0 transition-opacity duration-1000">

    <!-- Section 2: Experience (Retro Neo-Brutalism) -->
    <section id="experience" class="relative w-full bg-[var(--color-paper-white)] pt-[16px] pb-[60px] px-[24px]">
      <!-- Subtle Polka Dot Background Pattern -->
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#000 2px, transparent 2px); background-size: 24px 24px;"></div>
      
      <div class="relative max-w-[1400px] mx-auto z-10">
        <!-- Section Header -->
        <h2 class="scroll-reveal opacity-0 translate-y-[60px] transition-all duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] text-[40px] md:text-[56px] tracking-wider mb-[32px] text-[var(--color-carbon-black)]" style="font-family: 'Poppin', sans-serif;">Experience</h2>


        <!-- Snake Timeline Container (Retro OS Theme - Side Photo Restored) -->
        <div class="relative py-[8px] max-w-[1400px] mx-auto">
          <!-- Left Spine (Mobile only) -->
          <div class="block lg:hidden absolute left-[20px] top-[24px] bottom-[24px] w-[6px] bg-[var(--color-carbon-black)] z-0"></div>

          <!-- Grid Container -->
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-[40px] lg:gap-y-[80px] lg:gap-x-[160px] relative z-10 ml-[48px] lg:ml-0">
          
            <!-- Card 1: Jan - Mar 2026 (Top Left) -->
            <div class="scroll-reveal opacity-0 translate-y-[60px] transition-all duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] relative w-full bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[4px_4px_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_#000] transition-all group flex flex-col order-1 lg:order-1">
              
              <!-- Window Title Bar -->
              <div class="w-full bg-[#e0f2fe] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex justify-between items-center">
                <div class="flex gap-[6px]">
                  <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                </div>
                <div class="font-mono text-[11px] md:text-[12px] font-bold hidden sm:block">viskal_consulting.exe</div>
                <div class="w-[42px] hidden sm:block"></div> <!-- Spacer for centering -->
              </div>

              <div class="p-[20px] flex flex-col justify-between flex-1">
                <!-- Mobile Pin -->
                <div class="block lg:hidden absolute left-[-38px] top-[27px] w-[20px] h-[20px] bg-[#e0f2fe] border-[2px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:bg-[#ECA243] transition-colors"></div>
                <div class="block lg:hidden absolute left-[-28px] top-[34px] w-[28px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                
                <!-- Desktop Horizontal Connection to Card 2 -->
                <div class="hidden lg:block absolute right-[-160px] top-[34px] w-[160px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                <div class="hidden lg:block absolute right-[-90px] top-[27px] w-[20px] h-[20px] bg-[#fca5a5] border-[2.5px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:scale-110 transition-transform"></div>

                <div>
                  <div class="flex flex-col xl:flex-row justify-between items-start mb-[10px] gap-[6px]">
                    <div>
                      <h3 class="text-[20px] md:text-[24px] font-black tracking-tight leading-[1.2] mb-[2px]" style="font-family: 'Chalkboard', cursive;">Odoo & Web App Assistant</h3>
                      <p class="text-[13px] md:text-[14px] font-bold text-[#3b82f6]" style="font-family: 'Chalkboard', cursive;">Viskal Consulting</p>
                    </div>
                    <div class="bg-[#e0f2fe] border-[2px] border-[var(--color-carbon-black)] px-[8px] py-[2px] shadow-[2px_2px_0_#000] font-mono font-bold text-[11px] whitespace-nowrap self-start">
                      Jan - Mar 2026
                    </div>
                  </div>
                  
                  <div class="flex flex-col xl:flex-row gap-[16px] items-center xl:items-start mb-[16px]">
                    <ul class="list-disc ml-[16px] text-[12px] md:text-[13px] leading-[1.5] font-medium font-mono text-[var(--color-carbon-black)] flex-1 flex flex-col gap-1.5">
                      <li>Maintained the Odoo ERP system and assisted in configuring HR and Attendance modules for internal operations.</li>
                      <li>Managed website updates using WordPress, including publishing content and improving basic SEO.</li>
                      <li>Created promotional flyer designs to support marketing activities.</li>
                    </ul>
                    
                    <!-- Retro Image Viewer (Carousel) -->
                    <div class="retro-carousel w-[160px] h-[180px] flex-shrink-0 bg-[var(--color-paper-white)] border-[2.5px] border-[var(--color-carbon-black)] shadow-[3px_3px_0_#000] flex flex-col mt-[4px] xl:mt-0 transition-transform group-hover:scale-105" data-images='["/images/viskal_1.jpg", "/images/viskal_2.jpg", "/images/viskal_3.jpg"]' data-index="2">
                      <div class="border-b-[2.5px] border-[var(--color-carbon-black)] bg-gray-200 p-[2px] px-[4px] flex justify-between items-center">
                        <span class="text-[8px] font-mono border-[1.5px] border-[var(--color-carbon-black)] px-1 bg-[#d8b4fe] hidden sm:block">CLICK</span>
                        <span class="carousel-title text-[8px] font-mono font-bold uppercase truncate max-w-[70px]">viskal_3.jpg</span>
                        <div class="w-[10px] h-[10px] bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-sm flex items-center justify-center flex-shrink-0"><div class="w-[5px] h-[1.5px] bg-[var(--color-carbon-black)]"></div></div>
                      </div>
                      <div class="flex-1 bg-gray-100 flex items-center justify-center relative p-[4px] min-h-0">
                          <img src="/images/viskal_3.jpg" alt="Viskal Consulting" class="carousel-img w-full h-full object-cover border-[1.5px] border-[var(--color-carbon-black)] cursor-pointer hover:opacity-80 transition-opacity" />
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="flex flex-wrap gap-[8px]">
                  <span class="bg-[#e0f2fe] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Odoo ERP</span>
                  <span class="bg-[#e0f2fe] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">WordPress</span>
                  <span class="bg-[#e0f2fe] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">SEO</span>
                </div>
              </div>
            </div>

            <!-- Card 2: Sep - Dec 2025 (Top Right) -->
            <div class="scroll-reveal opacity-0 translate-y-[60px] transition-all duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] delay-100 relative w-full bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[4px_4px_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_#000] transition-all group flex flex-col order-2 lg:order-2">
              
              <!-- Window Title Bar -->
              <div class="w-full bg-[#fef3c8] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex justify-between items-center">
                <div class="flex gap-[6px]">
                  <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                </div>
                <div class="font-mono text-[11px] md:text-[12px] font-bold hidden sm:block">the_cube_group.exe</div>
                <div class="w-[42px] hidden sm:block"></div>
              </div>

              <div class="p-[20px] flex flex-col justify-between flex-1">
                <!-- Mobile Pin -->
                <div class="block lg:hidden absolute left-[-38px] top-[27px] w-[20px] h-[20px] bg-[#fef3c8] border-[2px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:bg-[#ECA243] transition-colors"></div>
                <div class="block lg:hidden absolute left-[-28px] top-[34px] w-[28px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                
                <!-- Desktop Vertical Connection to Card 3 -->
                <div class="hidden lg:block absolute left-1/2 bottom-[-80px] w-[6px] h-[80px] bg-[var(--color-carbon-black)] -translate-x-1/2 z-10"></div>
                <div class="hidden lg:block absolute left-1/2 bottom-[-50px] w-[20px] h-[20px] bg-[#fbbf25] border-[2.5px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] -translate-x-1/2 z-20 group-hover:scale-110 transition-transform"></div>

                <div>
                  <div class="flex flex-col xl:flex-row justify-between items-start mb-[10px] gap-[6px]">
                    <div>
                      <h3 class="text-[20px] md:text-[24px] font-black tracking-tight leading-[1.2] mb-[2px]" style="font-family: 'Chalkboard', cursive;">Coding Mentor</h3>
                      <p class="text-[13px] md:text-[14px] font-bold text-[#eab308]" style="font-family: 'Chalkboard', cursive;">The Cube Group (SD 03)</p>
                    </div>
                    <div class="bg-[#fef3c8] border-[2px] border-[var(--color-carbon-black)] px-[8px] py-[2px] shadow-[2px_2px_0_#000] font-mono font-bold text-[11px] whitespace-nowrap self-start">
                      Sep - Dec 2025
                    </div>
                  </div>
                  
                  <div class="flex flex-col xl:flex-row gap-[16px] items-center xl:items-start mb-[16px]">
                    <ul class="list-disc ml-[16px] text-[12px] md:text-[13px] leading-[1.5] font-medium font-mono text-[var(--color-carbon-black)] flex-1 flex flex-col gap-1.5">
                      <li>Designed a structured coding curriculum introducing fundamental algorithms and logical thinking using Scratch.</li>
                      <li>Evaluated students' code to identify logic errors and guided them through the debugging process.</li>
                    </ul>
                    
                    <!-- Retro Image Viewer (Carousel) -->
                    <div class="retro-carousel w-[160px] h-[180px] flex-shrink-0 bg-[var(--color-paper-white)] border-[2.5px] border-[var(--color-carbon-black)] shadow-[3px_3px_0_#000] flex flex-col mt-[4px] xl:mt-0 transition-transform group-hover:scale-105" data-images='["/images/coding mentor_1.jpg", "/images/coding_mentor_2.jpg", "/images/coding mentor-3.jpg"]' data-index="2">
                      <div class="border-b-[2.5px] border-[var(--color-carbon-black)] bg-gray-200 p-[2px] px-[4px] flex justify-between items-center">
                        <span class="text-[8px] font-mono border-[1.5px] border-[var(--color-carbon-black)] px-1 bg-[#d8b4fe] hidden sm:block">CLICK</span>
                        <span class="carousel-title text-[8px] font-mono font-bold uppercase truncate max-w-[70px]">coding mentor-3.jpg</span>
                        <div class="w-[10px] h-[10px] bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-sm flex items-center justify-center flex-shrink-0"><div class="w-[5px] h-[1.5px] bg-[var(--color-carbon-black)]"></div></div>
                      </div>
                      <div class="flex-1 bg-gray-100 flex items-center justify-center relative p-[4px] min-h-0">
                          <img src="/images/coding mentor-3.jpg" alt="Coding Mentor" class="carousel-img w-full h-full object-cover border-[1.5px] border-[var(--color-carbon-black)] cursor-pointer hover:opacity-80 transition-opacity" />
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="flex flex-wrap gap-[8px]">
                  <span class="bg-[#fef3c8] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Scratch</span>
                  <span class="bg-[#fef3c8] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Mentoring</span>
                </div>
              </div>
            </div>

            <!-- Card 3: Apr - Jun 2025 (Bottom Right) -->
            <div class="scroll-reveal opacity-0 translate-y-[60px] transition-all duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] delay-[200ms] relative w-full bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[4px_4px_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_#000] transition-all group flex flex-col order-3 lg:order-4">
              
              <!-- Window Title Bar -->
              <div class="w-full bg-[#d2fae5] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex justify-between items-center">
                <div class="flex gap-[6px]">
                  <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                </div>
                <div class="font-mono text-[11px] md:text-[12px] font-bold hidden sm:block">udayana_univ.exe</div>
                <div class="w-[42px] hidden sm:block"></div>
              </div>

              <div class="p-[20px] flex flex-col justify-between flex-1">
                <!-- Mobile Pin -->
                <div class="block lg:hidden absolute left-[-38px] top-[27px] w-[20px] h-[20px] bg-[#d2fae5] border-[2px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:bg-[#ECA243] transition-colors"></div>
                <div class="block lg:hidden absolute left-[-28px] top-[34px] w-[28px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                
                <!-- Desktop Horizontal Connection to Card 4 -->
                <div class="hidden lg:block absolute left-[-160px] top-[34px] w-[160px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                <div class="hidden lg:block absolute left-[-90px] top-[27px] w-[20px] h-[20px] bg-[#a3e635] border-[2.5px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:scale-110 transition-transform"></div>

                <div>
                  <div class="flex flex-col xl:flex-row justify-between items-start mb-[10px] gap-[6px]">
                    <div>
                      <h3 class="text-[20px] md:text-[24px] font-black tracking-tight leading-[1.2] mb-[2px]" style="font-family: 'Chalkboard', cursive;">Network Assistant</h3>
                      <p class="text-[13px] md:text-[14px] font-bold text-[#22c55e]" style="font-family: 'Chalkboard', cursive;">Udayana University</p>
                    </div>
                    <div class="bg-[#d2fae5] border-[2px] border-[var(--color-carbon-black)] px-[8px] py-[2px] shadow-[2px_2px_0_#000] font-mono font-bold text-[11px] whitespace-nowrap self-start">
                      Apr - Jun 2025
                    </div>
                  </div>
                  
                  <div class="flex flex-col xl:flex-row gap-[16px] items-center xl:items-start mb-[16px]">
                    <ul class="list-disc ml-[16px] text-[12px] md:text-[13px] leading-[1.5] font-medium font-mono text-[var(--color-carbon-black)] flex-1 flex flex-col gap-1.5">
                      <li>Facilitated network lab sessions and diagnosed connectivity issues using Cisco Packet Tracer and Linux.</li>
                      <li>Mentored first-year students in understanding network protocols and topology design.</li>
                    </ul>
                    
                    <div class="retro-carousel w-[160px] h-[180px] flex-shrink-0 bg-[var(--color-paper-white)] border-[2.5px] border-[var(--color-carbon-black)] shadow-[3px_3px_0_#000] flex flex-col mt-[4px] xl:mt-0 transition-transform group-hover:scale-105" data-images='["/images/practicum asistant.jpg"]' data-index="0">
                      <div class="border-b-[2.5px] border-[var(--color-carbon-black)] bg-gray-200 p-[2px] px-[4px] flex justify-between items-center">
                        <span class="text-[8px] font-mono border-[1.5px] border-[var(--color-carbon-black)] px-1 bg-[#d8b4fe] hidden sm:block">CLICK</span>
                        <span class="carousel-title text-[8px] font-mono font-bold uppercase truncate max-w-[70px]">lab.jpg</span>
                        <div class="w-[10px] h-[10px] bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-sm flex items-center justify-center flex-shrink-0"><div class="w-[5px] h-[1.5px] bg-[var(--color-carbon-black)]"></div></div>
                      </div>
                      <div class="flex-1 bg-gray-100 flex items-center justify-center relative p-[4px] min-h-0">
                          <img src="/images/practicum asistant.jpg" alt="Network Assistant" class="carousel-img w-full h-full object-cover border-[1.5px] border-[var(--color-carbon-black)] cursor-pointer hover:opacity-80 transition-opacity" />
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="flex flex-wrap gap-[8px]">
                  <span class="bg-[#d2fae5] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Packet Tracer</span>
                  <span class="bg-[#d2fae5] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Linux</span>
                </div>
              </div>
            </div>

            <!-- Card 4: Jul - Aug 2023 (Bottom Left) -->
            <div class="scroll-reveal opacity-0 translate-y-[60px] transition-all duration-[1000ms] ease-[cubic-bezier(0.16,1,0.3,1)] delay-[300ms] relative w-full bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[4px_4px_0_#000] hover:-translate-y-1 hover:shadow-[6px_6px_0_#000] transition-all group flex flex-col order-4 lg:order-3">
              
              <!-- Window Title Bar -->
              <div class="w-full bg-[#fae9ff] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex justify-between items-center">
                <div class="flex gap-[6px]">
                  <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                  <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
                </div>
                <div class="font-mono text-[11px] md:text-[12px] font-bold hidden sm:block">biasa_group.exe</div>
                <div class="w-[42px] hidden sm:block"></div>
              </div>

              <div class="p-[20px] flex flex-col justify-between flex-1">
                <!-- Mobile Pin -->
                <div class="block lg:hidden absolute left-[-38px] top-[27px] w-[20px] h-[20px] bg-[#fae9ff] border-[2px] border-[var(--color-carbon-black)] rounded-full shadow-[2px_2px_0_#000] z-20 group-hover:bg-[#ECA243] transition-colors"></div>
                <div class="block lg:hidden absolute left-[-28px] top-[34px] w-[28px] h-[6px] bg-[var(--color-carbon-black)] z-10"></div>
                
                <!-- No Desktop Pin because it's the end of the snake! -->

                <div>
                  <div class="flex flex-col xl:flex-row justify-between items-start mb-[10px] gap-[6px]">
                    <div>
                      <h3 class="text-[20px] md:text-[24px] font-black tracking-tight leading-[1.2] mb-[2px]" style="font-family: 'Chalkboard', cursive;">Accounting Staff</h3>
                      <p class="text-[13px] md:text-[14px] font-bold text-[#d946ef]" style="font-family: 'Chalkboard', cursive;">BIASA Group</p>
                    </div>
                    <div class="bg-[#fae9ff] border-[2px] border-[var(--color-carbon-black)] px-[8px] py-[2px] shadow-[2px_2px_0_#000] font-mono font-bold text-[11px] whitespace-nowrap self-start">
                      Jul - Aug 2023
                    </div>
                  </div>
                  
                  <div class="flex flex-col xl:flex-row gap-[16px] items-center xl:items-start mb-[16px]">
                    <ul class="list-disc ml-[16px] text-[12px] md:text-[13px] leading-[1.5] font-medium font-mono text-[var(--color-carbon-black)] flex-1 flex flex-col gap-1.5">
                      <li>Conducted rigorous data entry and verification for financial records, ensuring high accuracy.</li>
                      <li>Assisted senior staff in cross-checking reports to identify discrepancies.</li>
                    </ul>
                    
                    <div class="retro-carousel w-[160px] h-[180px] flex-shrink-0 bg-[var(--color-paper-white)] border-[2.5px] border-[var(--color-carbon-black)] shadow-[3px_3px_0_#000] flex flex-col mt-[4px] xl:mt-0 transition-transform group-hover:scale-105" data-images='["/images/assistant staff.png"]' data-index="0">
                      <div class="border-b-[2.5px] border-[var(--color-carbon-black)] bg-gray-200 p-[2px] px-[4px] flex justify-between items-center">
                        <span class="text-[8px] font-mono border-[1.5px] border-[var(--color-carbon-black)] px-1 bg-[#d8b4fe] hidden sm:block">CLICK</span>
                        <span class="carousel-title text-[8px] font-mono font-bold uppercase truncate max-w-[70px]">biasa.jpg</span>
                        <div class="w-[10px] h-[10px] bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-sm flex items-center justify-center flex-shrink-0"><div class="w-[5px] h-[1.5px] bg-[var(--color-carbon-black)]"></div></div>
                      </div>
                      <div class="flex-1 bg-gray-100 flex items-center justify-center relative p-[4px] min-h-0">
                          <img src="/images/assistant staff.png" alt="Accounting Staff" class="carousel-img w-full h-full object-cover border-[1.5px] border-[var(--color-carbon-black)] cursor-pointer hover:opacity-80 transition-opacity" />
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="flex flex-wrap gap-[8px]">
                  <span class="bg-[#fae9ff] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Data Entry</span>
                  <span class="bg-[#fae9ff] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] text-[10px] font-bold shadow-[2px_2px_0_#000] font-mono">Accounting</span>
                </div>
