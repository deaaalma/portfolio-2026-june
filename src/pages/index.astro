    <!-- Lightbox Script -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const carousels = document.querySelectorAll('.retro-carousel');
        
        // AGGRESSIVE PRELOADING
        carousels.forEach(carousel => {
          const imagesStr = carousel.dataset.images;
          if (imagesStr) {
            try {
              const images = JSON.parse(imagesStr);
              images.forEach(src => {
                 const img = new Image();
                 img.src = src;
              });
            } catch(e) {}
          }
        });

        const lightbox = document.getElementById('retro-lightbox');
        const lightboxImgContainer = document.getElementById('lightbox-img-container');
        const lightboxTitle = document.getElementById('lightbox-title');
        const lightboxCounter = document.getElementById('lightbox-counter');
        const btnClose = document.getElementById('lightbox-close');
        const btnPrev = document.getElementById('lightbox-prev');
        const btnNext = document.getElementById('lightbox-next');
        
        let currentLightboxImages = [];
        let currentLightboxIndex = 0;
        let originalTitleElement = null;
        let originalImgElement = null;

        const updateLightbox = () => {
          if (currentLightboxImages.length === 0) return;
          const src = currentLightboxImages[currentLightboxIndex];
          
          // Toggle opacity for 0ms delay DOM swap
          Array.from(lightboxImgContainer.children).forEach((img, idx) => {
             img.style.opacity = idx === currentLightboxIndex ? '1' : '0';
             img.style.zIndex = idx === currentLightboxIndex ? '10' : '0';
          });

          const filename = src.split('/').pop();
          lightboxTitle.textContent = filename;
          lightboxCounter.textContent = `${currentLightboxIndex + 1} of ${currentLightboxImages.length}`;
          
          // Also update the thumbnail view if applicable
          if (originalTitleElement) originalTitleElement.textContent = filename;
          if (originalImgElement) originalImgElement.src = src;
        };

        const closeLightbox = () => {
          lightbox.classList.add('hidden');
          lightbox.classList.remove('flex');
          document.body.style.overflow = ''; // Restore scroll
        };

        const openLightbox = (images, startIndex, imgEl, titleEl) => {
          currentLightboxImages = images;
          currentLightboxIndex = startIndex;
          originalImgElement = imgEl;
          originalTitleElement = titleEl;
          
          if (images.length <= 1) {
              btnPrev.style.display = 'none';
              btnNext.style.display = 'none';
          } else {
              btnPrev.style.display = '';
              btnNext.style.display = '';
          }
          
          // Clear and inject all images to DOM to force browser decode
          lightboxImgContainer.innerHTML = '';
          images.forEach((src, idx) => {
             const img = document.createElement('img');
             img.src = src;
             img.className = 'absolute top-0 left-0 w-full h-full object-cover transition-opacity duration-200';
             img.style.opacity = idx === startIndex ? '1' : '0';
             img.style.zIndex = idx === startIndex ? '10' : '0';
             lightboxImgContainer.appendChild(img);
          });

          updateLightbox();
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
          document.body.style.overflow = 'hidden'; // Prevent scroll
        };

        // Attach click handlers to inline thumbnails
        carousels.forEach(carousel => {
          const imagesStr = carousel.dataset.images;
          if (!imagesStr) return;
          const images = JSON.parse(imagesStr);
          if (images.length === 0) return;
          
          let startIndex = parseInt(carousel.dataset.index || '0');
          const imgElement = carousel.querySelector('.carousel-img');
          const titleElement = carousel.querySelector('.carousel-title');
          
          imgElement.addEventListener('click', () => {
             openLightbox(images, startIndex, imgElement, titleElement);
          });
        });

        // Lightbox buttons
        btnClose.addEventListener('click', closeLightbox);
        
        // Close on clicking outside the modal box
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) {
            closeLightbox();
          }
        });

        btnPrev.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (currentLightboxImages.length === 0) return;
            currentLightboxIndex = (currentLightboxIndex - 1 + currentLightboxImages.length) % currentLightboxImages.length;
            updateLightbox();
        });

        btnNext.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (currentLightboxImages.length === 0) return;
            currentLightboxIndex = (currentLightboxIndex + 1) % currentLightboxImages.length;
            updateLightbox();
        });
        
        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
           if (!lightbox.classList.contains('hidden')) {
              if (e.key === 'Escape') closeLightbox();
              if (e.key === 'ArrowLeft') btnPrev.click();
              if (e.key === 'ArrowRight') btnNext.click();
           }
        });
      });
    </script>

<script>
        const initBadgeSFX = () => {
            if (window.__badgeSfxInitialized) return;
            window.__badgeSfxInitialized = true;

            const badges = Array.from(document.querySelectorAll('span.font-mono')).filter(el => 
                el.className.includes('border-') && el.className.includes('shadow-')
            );
            
            let audioCtx = null;
            let unlocked = false;

            const playPop = () => {
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if (audioCtx.state === 'suspended') audioCtx.resume();

                const osc = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();

                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.05);

                gainNode.gain.setValueAtTime(0.15, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);

                osc.connect(gainNode);
                gainNode.connect(audioCtx.destination);

                osc.start();
                osc.stop(audioCtx.currentTime + 0.05);
            };

            const unlockAudio = () => {
                if (unlocked) return;
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if (audioCtx.state === 'suspended') audioCtx.resume();
                unlocked = true;
                window.removeEventListener('click', unlockAudio);
                window.removeEventListener('keydown', unlockAudio);
            };
            window.addEventListener('click', unlockAudio);
            window.addEventListener('keydown', unlockAudio);

            badges.forEach(badge => {
                badge.style.transition = 'transform 0.1s ease-in-out';
                badge.style.cursor = 'pointer';
                badge.addEventListener('mouseenter', () => {
                    playPop();
                    badge.style.transform = 'scale(1.05) rotate(-1deg)';
                });
                badge.addEventListener('mouseleave', () => {
                    badge.style.transform = 'scale(1) rotate(0deg)';
                });
            });
        };

        const initBadgeHoverEffect = () => {
            if (window.__badgeHoverInitialized) return;
            window.__badgeHoverInitialized = true;

            // Find all cards that contain badges
            const allCards = Array.from(document.querySelectorAll('div')).filter(el => 
                el.className.includes('border-[3px]') && 
                el.querySelector('.flex-wrap.gap-\\[8px\\] span.font-mono')
            );

            const allBadges = document.querySelectorAll('.flex-wrap.gap-\\[8px\\] span.font-mono');

            allBadges.forEach(badge => {
                badge.style.cursor = 'pointer';
                // Add a small hover scale to the badge itself
                badge.style.transition = 'transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1)';
                
                badge.addEventListener('mouseenter', () => {
                    badge.style.transform = 'scale(1.1)';
                    const badgeText = badge.textContent.trim();
                    
                    allCards.forEach(card => {
                        // Check if this card contains the badge
                        const cardBadges = Array.from(card.querySelectorAll('.flex-wrap.gap-\\[8px\\] span.font-mono'));
                        const hasBadge = cardBadges.some(b => b.textContent.trim() === badgeText);
                        
                        // Override standard hover transforms so it doesn't fight with Tailwind
                        card.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                        
                        if (hasBadge) {
                            card.style.opacity = '1';
                            card.style.filter = 'brightness(1.05)';
                            card.style.transform = 'translateY(-4px)';
                            card.style.boxShadow = '8px 8px 0 #000';
                            card.style.zIndex = '10';
                        } else {
                            card.style.opacity = '0.3';
                            card.style.filter = 'grayscale(100%) blur(1px)';
                            card.style.transform = 'scale(0.98)';
                            card.style.boxShadow = '2px 2px 0 #000';
                            card.style.zIndex = '1';
                        }
                    });
                });

                badge.addEventListener('mouseleave', () => {
                    badge.style.transform = '';
                    allCards.forEach(card => {
                        card.style.opacity = '';
                        card.style.filter = '';
                        card.style.transform = '';
                        card.style.boxShadow = '';
                        card.style.zIndex = '';
                        
                        // We need to clear inline styles so Tailwind hover effects work again
                        setTimeout(() => {
                           if (!card.style.opacity) {
                               card.style.transition = '';
                           }
                        }, 300);
                    });
                });
            });
        };

        const initScrollReveal = () => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('opacity-0', 'translate-y-[60px]');
                        entry.target.classList.add('opacity-100', 'translate-y-0');
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.15,
                rootMargin: '0px 0px -50px 0px'
            });

            document.querySelectorAll('.scroll-reveal').forEach((el) => {
                observer.observe(el);
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                initBadgeSFX();
                initBadgeHoverEffect();
                initScrollReveal();
            });
        } else {
            initBadgeSFX();
            initBadgeHoverEffect();
            initScrollReveal();
        }
        document.addEventListener('astro:page-load', () => {
            initBadgeSFX();
            initBadgeHoverEffect();
            initScrollReveal();
        });
</script>
