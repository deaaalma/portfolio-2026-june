---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoHd from '../assets/images/logo-hd.png';
---

<Layout title="My Projects">
  <!-- ========== FLOATING PILL NAVBAR ========== -->
  <header class="fixed top-[24px] left-1/2 -translate-x-1/2 w-[calc(100%-48px)] max-w-[900px] z-50">
    <nav class="flex items-center justify-between bg-[var(--color-paper-white)] border-[1.5px] border-[var(--color-carbon-black)] rounded-full px-[16px] py-[12px] shadow-[4px_4px_0_#000]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-[8px] pl-[12px] hover:opacity-70 transition-opacity">
        <Image src={logoHd} alt="Love Logo HD" width={32} class="w-[32px] h-[32px] object-contain drop-shadow-[1px_1px_0_#000]" />
        <span class="text-[20px] font-bold text-[var(--color-carbon-black)] tracking-tight">Dea Alma</span>
      </a>
      
      <!-- Right Side -->
      <div class="flex items-center gap-[36px]">
        <div class="hidden md:flex items-center gap-[36px]">
          <a href="/#about" class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">About</a>
          <a href="/#what-i-do" class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">What I Do</a>
          <a href="/#my-work" class="text-[15px] font-medium text-[var(--color-carbon-black)] hover:opacity-70 transition-opacity">My Work</a>
        </div>
        <div class="flex items-center gap-[12px]">
          <a href="/#contact" class="flex items-center gap-[8px] text-[15px] font-bold text-[var(--color-carbon-black)] border-[1.5px] border-[var(--color-carbon-black)] rounded-full px-[20px] py-[8px] bg-[var(--color-lime-pulse)] shadow-[2px_2px_0_#000] hover:brightness-95 transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Let's Talk
          </a>
        </div>
      </div>
    </nav>
  </header>

  <main class="pt-[72px] min-h-screen bg-[#f3e8ff] relative">
    <!-- Global Dot Grid Background -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none z-0" style="background-image: radial-gradient(#000 2px, transparent 2px); background-size: 24px 24px;"></div>

    <!-- ========== HEADER & FILTERS ========== -->
    <section class="relative w-full pt-[60px] md:pt-[80px] pb-[32px] px-[24px]">
      <div class="relative max-w-[1200px] mx-auto z-10">
        
        <!-- OS breadcrumb -->
        <div class="font-mono text-[12px] text-gray-500 mb-[24px] flex items-center gap-[6px] font-bold">
          <a href="/" class="hover:text-[var(--color-carbon-black)] transition-colors">C:\PORTFOLIO</a>
          <span class="text-gray-400">&gt;</span>
          <span class="text-[var(--color-carbon-black)]">PROJECTS\</span>
        </div>

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-[32px] mb-[48px]">
          <!-- Left: Title & Subtitle -->
          <div>
            <h1 class="text-[52px] md:text-[64px] font-black text-[var(--color-carbon-black)] leading-[1] tracking-tight mb-[12px]"
              style="font-family: 'Poppin', sans-serif;">
              My Projects
            </h1>
            <p class="font-mono text-[14px] md:text-[15px] text-gray-600 max-w-[500px] leading-[1.7]">
              Explore all the projects I've built from web applications to mobile apps. Real work, real purpose.
            </p>
          </div>

          <!-- Right: Box Filters -->
          <div class="flex items-center gap-[0px] border-[3px] border-[var(--color-carbon-black)] w-fit shadow-[4px_4px_0_#000] bg-white">
            <button data-filter="all"
              class="filter-btn active-filter px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider border-r-[3px] border-[var(--color-carbon-black)] transition-all hover:bg-[#a3e635]">
              All (5)
            </button>
            <button data-filter="web-app"
              class="filter-btn px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider border-r-[3px] border-[var(--color-carbon-black)] transition-all hover:bg-[#bfdbfe]">
              Web App (4)
            </button>
            <button data-filter="mobile"
              class="filter-btn px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider transition-all hover:bg-[#fca5a5]">
              Mobile (1)
            </button>
          </div>
        </div>

      </div>
    </section>

    <!-- ========== GRID ========== -->
    <section class="relative w-full pb-[80px] px-[24px]">

      <div class="relative max-w-[1200px] mx-auto z-10">

        <!-- Projects Grid -->
        <div id="projects-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-[32px] md:gap-[48px]">

          <!-- ===== CARD 1: Marketplace Web App — Live Demo only ===== -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <div class="w-full bg-[#bfdbfe] border-b-[3px] border-[var(--color-carbon-black)] px-[16px] py-[10px] flex items-center gap-[8px]">
              <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[11px] font-bold uppercase tracking-wider">Marketplace Web Application</span>
            </div>
            <div class="relative w-full aspect-video bg-[#e0f2fe] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10">
                <button type="button" class="preview-btn flex items-center gap-[8px] bg-white text-black border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  Preview
                </button>
                <a href="https://umkm.tiomahesa.com/" target="_blank" rel="noopener"
                  class="flex items-center gap-[8px] bg-[#a3e635] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Live Demo
                </a>
              </div>
            </div>
            <div class="p-[24px] md:p-[32px] flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#bfdbfe] border-[1.5px] border-[var(--color-carbon-black)] px-[12px] py-[4px] font-mono text-[11px] font-black uppercase tracking-wider shadow-[2px_2px_0_#000]">Web App</span>
                <span class="font-mono text-[12px] text-gray-400 font-bold">#01</span>
              </div>
              <h2 class="text-[24px] md:text-[28px] font-black tracking-tight mb-[10px]" style="font-family: 'Chalkboard', cursive;">Marketplace Web Application</h2>
              <p class="font-mono text-[13px] md:text-[14px] text-gray-600 leading-[1.7] mb-[24px] flex-grow">
                A service-based UMKM digitalization platform with full transaction flow order placement, status tracking, and integrated payment. Supports 4 roles: Customer, UMKM Admin, Staff, and Super Admin.
              </p>
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">Laravel</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">Livewire</span>
              </div>
            </div>
          </div>

          <!-- ===== CARD 2: Hospital Information System — GitHub only ===== -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <div class="w-full bg-[#fca5a5] border-b-[3px] border-[var(--color-carbon-black)] px-[16px] py-[10px] flex items-center gap-[8px]">
              <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[11px] font-bold uppercase tracking-wider">Hospital Information System</span>
            </div>
            <div class="relative w-full aspect-video bg-[#fff1f2] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10">
                <button type="button" class="preview-btn flex items-center gap-[8px] bg-white text-black border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  Preview
                </button>
                <a href="https://github.com/deaaalma/hospital-management-system" target="_blank" rel="noopener"
                  class="flex items-center gap-[8px] bg-[var(--color-paper-white)] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              </div>
            </div>
            <div class="p-[24px] md:p-[32px] flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#fca5a5] border-[1.5px] border-[var(--color-carbon-black)] px-[12px] py-[4px] font-mono text-[11px] font-black uppercase tracking-wider shadow-[2px_2px_0_#000]">Web App</span>
                <span class="font-mono text-[12px] text-gray-400 font-bold">#02</span>
              </div>
              <h2 class="text-[24px] md:text-[28px] font-black tracking-tight mb-[10px]" style="font-family: 'Chalkboard', cursive;">Hospital Information System</h2>
              <p class="font-mono text-[13px] md:text-[14px] text-gray-600 leading-[1.7] mb-[24px] flex-grow">
                A fullstack web-based hospital management system for patient records and doctor scheduling. Implements RBAC across Admin, Doctor, and Customer roles validated through rigorous functional testing and documented with DFD & ERD.
              </p>
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">Laravel</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">MySQL</span>
              </div>
            </div>
          </div>

          <!-- ===== CARD 3: Secondhand Marketplace App — Mobile, GitHub only ===== -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="mobile">
            <div class="w-full bg-[#fae9ff] border-b-[3px] border-[var(--color-carbon-black)] px-[16px] py-[10px] flex items-center gap-[8px]">
              <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[11px] font-bold uppercase tracking-wider">Secondhand Marketplace App</span>
            </div>
            <div class="relative w-full aspect-video bg-[#fdf4ff] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[28px] h-[28px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10">
                <button type="button" class="preview-btn flex items-center gap-[8px] bg-white text-black border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  Preview
                </button>
                <a href="https://github.com/deaaalma/secondhand-marketplace-app" target="_blank" rel="noopener"
                  class="flex items-center gap-[8px] bg-[var(--color-paper-white)] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              </div>
            </div>
            <div class="p-[24px] md:p-[32px] flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#fae9ff] border-[1.5px] border-[var(--color-carbon-black)] px-[12px] py-[4px] font-mono text-[11px] font-black uppercase tracking-wider shadow-[2px_2px_0_#000]">Mobile</span>
                <span class="font-mono text-[12px] text-gray-400 font-bold">#03</span>
              </div>
              <h2 class="text-[24px] md:text-[28px] font-black tracking-tight mb-[10px]" style="font-family: 'Chalkboard', cursive;">Secondhand Marketplace App</h2>
              <p class="font-mono text-[13px] md:text-[14px] text-gray-600 leading-[1.7] mb-[24px] flex-grow">
                A mobile marketplace for secondhand goods built with Android Studio. Features OCR scanning for item listings, transaction management, and user verification developed as a team with a dedicated focus on manual QA testing.
              </p>
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">Kotlin</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[10px] py-[4px] font-mono text-[11px] font-bold shadow-[2px_2px_0_#000]">Android Studio</span>
              </div>
            </div>
          </div>

          <!-- ===== CARD 4: Transparas Blockchain — GitHub only ===== -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <div class="w-full bg-[#d2fae5] border-b-[3px] border-[var(--color-carbon-black)] px-[16px] py-[10px] flex items-center gap-[8px]">
              <div class="w-[12px] h-[12px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[12px] h-[12px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[11px] font-bold uppercase tracking-wider">Transparas</span>
            </div>
            <div class="relative w-full aspect-video bg-[#ecfdf5] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10">
                <button type="button" class="preview-btn flex items-center gap-[8px] bg-white text-black border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  Preview
