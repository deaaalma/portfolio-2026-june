---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Projects — Dea Alma">
  <!-- ========== RETRO OS NAVBAR ========== -->
  <header class="fixed top-0 left-0 w-full z-50 bg-[var(--color-paper-white)] border-b-[3px] border-[var(--color-carbon-black)] shadow-[0_3px_0_#000]">
    <div class="max-w-[1200px] mx-auto px-[24px] py-[12px] flex items-center justify-between">
      <!-- Logo / Back -->
      <a href="/" class="flex items-center gap-[10px] font-mono font-black text-[14px] hover:opacity-70 transition-opacity group">
        <svg class="w-[18px] h-[18px] group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        <img src="/images/logo-hd.png" alt="Logo" class="w-[28px] h-[28px] object-contain" />
        <span>Dea Alma</span>
      </a>

      <!-- Title chip -->
      <div class="hidden md:flex items-center gap-[8px] border-[2px] border-[var(--color-carbon-black)] bg-[#a3e635] px-[12px] py-[4px] shadow-[2px_2px_0_#000] font-mono font-black text-[12px] uppercase tracking-widest">
        <span class="w-[6px] h-[6px] bg-[var(--color-carbon-black)] inline-block"></span>
        MY_PROJECTS.EXE
        <span class="w-[6px] h-[6px] bg-[var(--color-carbon-black)] inline-block"></span>
      </div>

      <!-- Right: status -->
      <div class="font-mono text-[11px] text-gray-500 font-bold hidden md:block">
        6 files found
      </div>
    </div>
  </header>

  <main class="pt-[72px] min-h-screen bg-[var(--color-paper-white)]">

    <!-- ========== HERO HEADER ========== -->
    <section class="relative w-full bg-[var(--color-carbon-black)] py-[60px] md:py-[80px] px-[24px] overflow-hidden border-b-[4px] border-[var(--color-carbon-black)]">
      <!-- Scanline overlay -->
      <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, #fff 2px, #fff 4px);"></div>
      <!-- Dot grid -->
      <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(#a3e635 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>

      <div class="relative max-w-[1200px] mx-auto z-10 flex flex-col md:flex-row items-start md:items-end justify-between gap-[32px]">
        <div>
          <!-- OS breadcrumb -->
          <div class="font-mono text-[12px] text-gray-500 mb-[16px] flex items-center gap-[6px]">
            <a href="/" class="hover:text-[#a3e635] transition-colors">C:\PORTFOLIO</a>
            <span class="text-gray-600">&gt;</span>
            <span class="text-[#a3e635]">PROJECTS\</span>
          </div>

          <h1 class="text-[52px] md:text-[72px] font-black text-[var(--color-paper-white)] leading-[1] tracking-tight mb-[16px]"
            style="font-family: 'Poppin', sans-serif; -webkit-text-stroke: 1px #a3e635; text-shadow: 4px 4px 0 #a3e635;">
            My Projects
          </h1>
          <p class="font-mono text-[14px] md:text-[16px] text-gray-400 max-w-[500px] leading-[1.7]">
            Explore all the projects I've built — from web applications to mobile apps. Real work, real purpose.
          </p>
        </div>

        <!-- Stats box -->
        <div class="flex gap-[16px] flex-wrap">
          <div class="bg-[var(--color-paper-white)] border-[3px] border-[#a3e635] shadow-[4px_4px_0_#a3e635] px-[20px] py-[12px] text-center">
            <div class="font-black text-[32px] text-[var(--color-carbon-black)]">6</div>
            <div class="font-mono text-[10px] font-bold text-gray-600 uppercase tracking-widest">Projects</div>
          </div>
          <div class="bg-[var(--color-paper-white)] border-[3px] border-[#bfdbfe] shadow-[4px_4px_0_#bfdbfe] px-[20px] py-[12px] text-center">
            <div class="font-black text-[32px] text-[var(--color-carbon-black)]">3</div>
            <div class="font-mono text-[10px] font-bold text-gray-600 uppercase tracking-widest">Web App</div>
          </div>
          <div class="bg-[var(--color-paper-white)] border-[3px] border-[#fca5a5] shadow-[4px_4px_0_#fca5a5] px-[20px] py-[12px] text-center">
            <div class="font-black text-[32px] text-[var(--color-carbon-black)]">3</div>
            <div class="font-mono text-[10px] font-bold text-gray-600 uppercase tracking-widest">Mobile</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FILTER + GRID ========== -->
    <section class="relative w-full py-[48px] md:py-[64px] px-[24px]">
      <!-- Subtle dot bg -->
      <div class="absolute inset-0 opacity-[0.025] pointer-events-none" style="background-image: radial-gradient(#000 2px, transparent 2px); background-size: 28px 28px;"></div>

      <div class="relative max-w-[1200px] mx-auto z-10">

        <!-- Filter Tabs (retro OS style) -->
        <div class="flex items-center gap-[0px] mb-[48px] border-[3px] border-[var(--color-carbon-black)] w-fit shadow-[4px_4px_0_#000] overflow-hidden">
          <button data-filter="all"
            class="filter-btn active-filter px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider border-r-[3px] border-[var(--color-carbon-black)] transition-all hover:bg-[#a3e635]">
            All (6)
          </button>
          <button data-filter="web-app"
            class="filter-btn px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider border-r-[3px] border-[var(--color-carbon-black)] transition-all hover:bg-[#bfdbfe]">
            Web App (3)
          </button>
          <button data-filter="mobile"
            class="filter-btn px-[20px] py-[10px] font-mono font-black text-[12px] uppercase tracking-wider transition-all hover:bg-[#fca5a5]">
            Mobile (3)
          </button>
        </div>

        <!-- Projects Grid -->
        <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-[32px] md:gap-[40px]">

          <!-- ===== PROJECT CARD TEMPLATE ===== -->
          <!-- Card 1: Web App -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <!-- Window Title Bar -->
            <div class="w-full bg-[#bfdbfe] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex items-center gap-[6px]">
              <div class="w-[10px] h-[10px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[9px] font-bold uppercase tracking-wider">project_01.exe</span>
            </div>

            <!-- Screenshot / Placeholder -->
            <div class="relative w-full aspect-video bg-[#e0f2fe] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <!-- Replace with: <img src="/images/project_name.jpg" alt="..." class="w-full h-full object-cover" /> -->
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <!-- Hover Overlay with Buttons -->
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <a href="#" target="_blank" rel="noopener"
                  class="flex items-center gap-[8px] bg-[#a3e635] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Live Demo
                </a>
                <a href="#" target="_blank" rel="noopener"
                  class="flex items-center gap-[8px] bg-[var(--color-paper-white)] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              </div>
            </div>

            <!-- Card Body -->
            <div class="p-[20px] flex flex-col flex-grow">
              <!-- Category + Number -->
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#bfdbfe] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] font-mono text-[9px] font-black uppercase tracking-wider shadow-[1.5px_1.5px_0_#000]">Web App</span>
                <span class="font-mono text-[10px] text-gray-400 font-bold">#01</span>
              </div>
              <h2 class="text-[18px] font-black tracking-tight mb-[6px]" style="font-family: 'Chalkboard', cursive;">Project Name Here</h2>
              <p class="font-mono text-[11px] text-gray-600 leading-[1.6] mb-[16px] flex-grow">
                Short description of what this project does and what problem it solves. Keep it concise and clear.
              </p>
              <!-- Tech Stack Tags -->
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">React</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">Node.js</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">MySQL</span>
              </div>
            </div>
          </div>

          <!-- Card 2: Web App -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <div class="w-full bg-[#fef3c8] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex items-center gap-[6px]">
              <div class="w-[10px] h-[10px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[9px] font-bold uppercase tracking-wider">project_02.exe</span>
            </div>
            <div class="relative w-full aspect-video bg-[#fef9e7] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                <span class="font-mono text-[10px] font-bold">[ screenshot ]</span>
              </div>
              <div class="absolute inset-0 bg-black/80 flex flex-col items-center justify-center gap-[12px] opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <a href="#" target="_blank" rel="noopener" class="flex items-center gap-[8px] bg-[#a3e635] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Live Demo
                </a>
                <a href="#" target="_blank" rel="noopener" class="flex items-center gap-[8px] bg-[var(--color-paper-white)] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              </div>
            </div>
            <div class="p-[20px] flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#fef3c8] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] font-mono text-[9px] font-black uppercase tracking-wider shadow-[1.5px_1.5px_0_#000]">Web App</span>
                <span class="font-mono text-[10px] text-gray-400 font-bold">#02</span>
              </div>
              <h2 class="text-[18px] font-black tracking-tight mb-[6px]" style="font-family: 'Chalkboard', cursive;">Project Name Here</h2>
              <p class="font-mono text-[11px] text-gray-600 leading-[1.6] mb-[16px] flex-grow">
                Short description of what this project does and what problem it solves. Keep it concise and clear.
              </p>
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">Laravel</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">PHP</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">TailwindCSS</span>
              </div>
            </div>
          </div>

          <!-- Card 3: Web App -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="web-app">
            <div class="w-full bg-[#d2fae5] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex items-center gap-[6px]">
              <div class="w-[10px] h-[10px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[9px] font-bold uppercase tracking-wider">project_03.exe</span>
            </div>
            <div class="relative w-full aspect-video bg-[#ecfdf5] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
              <div class="flex flex-col items-center gap-[8px] opacity-50">
                <svg class="w-[32px] h-[32px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
