                <a href="#" target="_blank" rel="noopener" class="flex items-center gap-[8px] bg-[#a3e635] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  Live Demo
                </a>
                <a href="#" target="_blank" rel="noopener" class="flex items-center gap-[8px] bg-[var(--color-paper-white)] border-[2px] border-[var(--color-carbon-black)] px-[16px] py-[8px] font-mono font-black text-[11px] uppercase tracking-wider shadow-[3px_3px_0_#000] hover:translate-y-[1px] hover:shadow-[2px_2px_0_#000] transition-all w-[160px] justify-center">
                  <svg class="w-[14px] h-[14px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  GitHub
                </a>
              </div>
            </div>
            <div class="p-[20px] flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-[10px]">
                <span class="bg-[#d2fae5] border-[1.5px] border-[var(--color-carbon-black)] px-[8px] py-[2px] font-mono text-[9px] font-black uppercase tracking-wider shadow-[1.5px_1.5px_0_#000]">Web App</span>
                <span class="font-mono text-[10px] text-gray-400 font-bold">#03</span>
              </div>
              <h2 class="text-[18px] font-black tracking-tight mb-[6px]" style="font-family: 'Chalkboard', cursive;">Project Name Here</h2>
              <p class="font-mono text-[11px] text-gray-600 leading-[1.6] mb-[16px] flex-grow">
                Short description of what this project does and what problem it solves. Keep it concise and clear.
              </p>
              <div class="flex flex-wrap gap-[6px] mt-auto">
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">Python</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">Flask</span>
                <span class="bg-[#fef08a] border-[1.5px] border-[var(--color-carbon-black)] px-[7px] py-[1px] font-mono text-[9px] font-bold shadow-[1.5px_1.5px_0_#000]">SQLite</span>
              </div>
            </div>
          </div>

          <!-- Card 4: Mobile -->
          <div class="project-card group relative bg-[var(--color-paper-white)] border-[3px] border-[var(--color-carbon-black)] shadow-[5px_5px_0_#000] hover:-translate-y-1 hover:shadow-[8px_8px_0_#000] transition-all duration-200 flex flex-col"
            data-category="mobile">
            <div class="w-full bg-[#fca5a5] border-b-[3px] border-[var(--color-carbon-black)] px-[12px] py-[8px] flex items-center gap-[6px]">
              <div class="w-[10px] h-[10px] rounded-full bg-red-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-yellow-400 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <div class="w-[10px] h-[10px] rounded-full bg-green-500 border-[1.5px] border-[var(--color-carbon-black)]"></div>
              <span class="ml-auto font-mono text-[9px] font-bold uppercase tracking-wider">project_04.exe</span>
            </div>
            <div class="relative w-full aspect-video bg-[#fff1f2] border-b-[3px] border-[var(--color-carbon-black)] overflow-hidden flex items-center justify-center">
